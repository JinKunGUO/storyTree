# ===================================
# 支付宝支付配置
# ===================================

# 支付宝应用 ID（在支付宝开放平台创建应用后获取）
ALIPAY_APP_ID=

# 支付宝网关地址
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 应用私钥（自己生成的 RSA 私钥）
ALIPAY_PRIVATE_KEY=

# 支付宝公钥（支付宝开放平台提供的公钥）
ALIPAY_PUBLIC_KEY=

# 支付回调通知地址（必须是公网可访问的地址）
# 开发环境可以使用 ngrok 等工具将本地服务暴露到公网
ALIPAY_CALLBACK_URL=http://localhost:3001

# API 基础 URL（用于生成回调地址）
API_URL=http://localhost:3001

# ===================================
# 其他支付配置（预留）
# ===================================

# 微信支付配置（暂未实现）
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_KEY=
# WECHAT_PAY_CERT_PATH=
# WECHAT_PAY_KEY_PATH=

# Stripe 配置（暂未实现）
