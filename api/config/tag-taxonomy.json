{
  "version": "1.0",
  "description": "StoryTree 标签分类体系。添加新标签只需编辑此文件，前端通过 /api/tags/taxonomy 自动获取最新配置。",
  "dimensions": {
    "era": {
      "label": "时代",
      "description": "作品所属或描写的时代",
      "tags": ["先秦", "秦汉", "魏晋", "隋唐", "宋元", "明清", "近代", "当代"]
    },
    "genre": {
      "label": "类型",
      "description": "作品的文学类型/流派",
      "tags": [
        "武侠", "仙侠", "玄幻", "奇幻", "科幻",
        "都市", "言情", "悬疑推理", "恐怖灵异", "历史",
        "军事", "游戏竞技", "体育", "轻小说", "同人",
        "现实主义", "浪漫主义", "讽刺", "荒诞"
      ]
    },
    "form": {
      "label": "体裁",
      "description": "作品的文学形式",
      "tags": [
        "长篇小说", "中篇小说", "短篇小说", "短篇合集",
        "散文", "散文集", "诗歌", "诗集", "戏剧",
        "纪实", "杂文", "笔记", "评论", "学术"
      ]
    },
    "theme": {
      "label": "题材",
      "description": "作品的核心主题/元素",
      "tags": [
        "爱情", "冒险", "成长", "家族", "官场",
        "江湖", "校园", "职场", "末世", "穿越",
        "重生", "系统", "战争", "社会", "哲思",
        "乡土", "都市生活", "人性", "讽刺批判", "革命"
      ]
    },
    "audience": {
      "label": "受众",
      "description": "目标读者群",
      "tags": ["男频", "女频", "通用", "儿童", "青少年"]
    },
    "source": {
      "label": "来源",
      "description": "作品来源标识",
      "tags": ["公版书", "原创", "经典名著", "四大名著", "网文"]
    },
    "status": {
      "label": "状态",
      "description": "作品完结状态（自动标记）",
      "tags": ["已完结", "连载中"]
    }
  }
}
