generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model comments {
  id             Int        @id @default(autoincrement())
  content        String
  node_id        Int
  user_id        Int
  parent_id      Int?
  created_at     DateTime   @default(now())
  updated_at     DateTime
  comments       comments?  @relation("commentsTocomments", fields: [parent_id], references: [id])
  other_comments comments[] @relation("commentsTocomments")
  users          users      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  nodes          nodes      @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([parent_id])
  @@index([user_id])
  @@index([node_id])
}

model follows {
  id                                Int      @id @default(autoincrement())
  follower_id                       Int
  following_id                      Int
  created_at                        DateTime @default(now())
  users_follows_following_idTousers users    @relation("follows_following_idTousers", fields: [following_id], references: [id], onDelete: Cascade)
  users_follows_follower_idTousers  users    @relation("follows_follower_idTousers", fields: [follower_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@index([following_id])
  @@index([follower_id])
}

model nodes {
  id             Int        @id @default(autoincrement())
  story_id       Int
  parent_id      Int?
  author_id      Int
  title          String
  content        String
  image          String?
  path           String
  ai_generated   Boolean    @default(false)
  rating_avg     Float      @default(0)
  rating_count   Int        @default(0)
  read_count     Int        @default(0)
  review_status  String     @default("APPROVED")
  report_count   Int        @default(0)
  report_reasons String?
  reviewed_by    Int?
  reviewed_at    DateTime?
  review_note    String?
  created_at     DateTime   @default(now())
  updated_at     DateTime
  comments       comments[]
  nodes          nodes?     @relation("nodesTonodes", fields: [parent_id], references: [id])
  other_nodes    nodes[]    @relation("nodesTonodes")
  users          users      @relation(fields: [author_id], references: [id])
  stories        stories    @relation(fields: [story_id], references: [id], onDelete: Cascade)
  ratings        ratings[]
  reports        reports[]

  @@index([review_status])
  @@index([path])
  @@index([parent_id])
  @@index([story_id])
}

model notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  type       String
  title      String
  content    String
  link       String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([is_read])
  @@index([user_id])
}

model ratings {
  id         Int      @id @default(autoincrement())
  node_id    Int
  user_id    Int
  score      Int
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  nodes      nodes    @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@unique([node_id, user_id])
}

model reports {
  id          Int       @id @default(autoincrement())
  node_id     Int
  reporter_id Int
  reason      String
  description String?
  status      String    @default("pending")
  created_at  DateTime  @default(now())
  resolved_at DateTime?
  resolved_by Int?
  users       users     @relation(fields: [reporter_id], references: [id], onDelete: Cascade)
  nodes       nodes     @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@index([reporter_id])
  @@index([node_id])
}

model stories {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  cover_image  String?
  author_id    Int
  root_node_id Int?
  created_at   DateTime @default(now())
  updated_at   DateTime
  nodes        nodes[]
  users        users    @relation(fields: [author_id], references: [id])
}

model users {
  id                                  Int             @id @default(autoincrement())
  username                            String          @unique
  email                               String          @unique
  password                            String
  avatar                              String?
  bio                                 String?
  is_admin                            Boolean         @default(false)
  email_verified                      Boolean         @default(false)
  email_verification_token            String?
  email_verification_expires          DateTime?
  password_reset_token                String?
  password_reset_expires              DateTime?
  created_at                          DateTime        @default(now())
  updated_at                          DateTime
  comments                            comments[]
  follows_follows_following_idTousers follows[]       @relation("follows_following_idTousers")
  follows_follows_follower_idTousers  follows[]       @relation("follows_follower_idTousers")
  nodes                               nodes[]
  notifications                       notifications[]
  ratings                             ratings[]
  reports                             reports[]
  stories                             stories[]
}
