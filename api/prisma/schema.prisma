generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model bookmarks {
  id         Int      @id @default(autoincrement())
  user_id    Int
  story_id   Int
  created_at DateTime @default(now())
  story      stories  @relation(fields: [story_id], references: [id], onDelete: Cascade)
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, story_id])
  @@index([user_id])
  @@index([story_id])
}

model comments {
  id             Int        @id @default(autoincrement())
  content        String
  node_id        Int
  user_id        Int
  parent_id      Int?
  created_at     DateTime   @default(now())
  updated_at     DateTime
  comments       comments?  @relation("commentsTocomments", fields: [parent_id], references: [id])
  other_comments comments[] @relation("commentsTocomments")
  user           users      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  node           nodes      @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([parent_id])
  @@index([user_id])
  @@index([node_id])
}

model follows {
  id           Int      @id @default(autoincrement())
  follower_id  Int
  following_id Int
  created_at   DateTime @default(now())
  following    users    @relation("follows_following_idTousers", fields: [following_id], references: [id], onDelete: Cascade)
  follower     users    @relation("follows_follower_idTousers", fields: [follower_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@index([following_id])
  @@index([follower_id])
}

model nodes {
  id             Int        @id @default(autoincrement())
  story_id       Int
  parent_id      Int?
  author_id      Int
  title          String
  content        String
  image          String?
  path           String
  ai_generated   Boolean    @default(false)
  rating_avg     Float      @default(0)
  rating_count   Int        @default(0)
  read_count     Int        @default(0)
  review_status  String     @default("APPROVED")
  report_count   Int        @default(0)
  report_reasons String?
  reviewed_by    Int?
  reviewed_at    DateTime?
  review_note    String?
  created_at     DateTime   @default(now())
  updated_at     DateTime
  comments       comments[]
  nodes          nodes?     @relation("nodesTonodes", fields: [parent_id], references: [id])
  other_nodes    nodes[]    @relation("nodesTonodes")
  author         users      @relation("NodeAuthor", fields: [author_id], references: [id])
  story          stories    @relation(fields: [story_id], references: [id], onDelete: Cascade)
  ratings        ratings[]
  reports        reports[]
  shares         shares[]

  @@index([review_status])
  @@index([path])
  @@index([parent_id])
  @@index([story_id])
}

model notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  type       String
  title      String
  content    String
  link       String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([is_read])
  @@index([user_id])
}

model ratings {
  id         Int      @id @default(autoincrement())
  node_id    Int
  user_id    Int
  score      Int
  created_at DateTime @default(now())
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  node       nodes    @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@unique([node_id, user_id])
}

model reports {
  id          Int       @id @default(autoincrement())
  node_id     Int
  reporter_id Int
  reason      String
  description String?
  status      String    @default("pending")
  created_at  DateTime  @default(now())
  resolved_at DateTime?
  resolved_by Int?
  reporter    users     @relation(fields: [reporter_id], references: [id], onDelete: Cascade)
  node        nodes     @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@index([reporter_id])
  @@index([node_id])
}

model shares {
  id         Int      @id @default(autoincrement())
  story_id   Int
  node_id    Int?
  user_id    Int?
  platform   String
  created_at DateTime @default(now())
  user       users?   @relation(fields: [user_id], references: [id])
  node       nodes?   @relation(fields: [node_id], references: [id], onDelete: Cascade)
  story      stories  @relation(fields: [story_id], references: [id], onDelete: Cascade)

  @@index([story_id])
  @@index([node_id])
  @@index([user_id])
  @@index([platform])
  @@index([created_at])
}

model stories {
  id           Int         @id @default(autoincrement())
  title        String
  description  String?
  cover_image  String?
  author_id    Int
  root_node_id Int?
  created_at   DateTime    @default(now())
  updated_at   DateTime
  bookmarks    bookmarks[]
  nodes        nodes[]
  shares       shares[]
  author       users       @relation("StoryAuthor", fields: [author_id], references: [id])
}

model users {
  id                       Int             @id @default(autoincrement())
  username                 String          @unique
  email                    String          @unique
  password                 String
  avatar                   String?
  bio                      String?
  isAdmin                  Boolean         @default(false) @map("is_admin")
  emailVerified            Boolean         @default(false) @map("email_verified")
  emailVerificationToken   String?         @map("email_verification_token")
  emailVerificationExpires DateTime?       @map("email_verification_expires")
  passwordResetToken       String?         @map("password_reset_token")
  passwordResetExpires     DateTime?       @map("password_reset_expires")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @map("updated_at")
  ai_usage_logs            ai_usage_logs[]
  bookmarks                bookmarks[]
  comments                 comments[]
  following                follows[]       @relation("follows_following_idTousers")
  followers                follows[]       @relation("follows_follower_idTousers")
  authored_nodes           nodes[]         @relation("NodeAuthor")
  notifications            notifications[]
  ratings                  ratings[]
  reports                  reports[]
  shares                   shares[]
  authored_stories         stories[]       @relation("StoryAuthor")
}

model ai_usage_logs {
  id                Int      @id @default(autoincrement())
  user_id           Int
  story_id          Int?
  node_id           Int?
  action_type       String
  model_name        String
  prompt_tokens     Int      @default(0)
  completion_tokens Int      @default(0)
  total_tokens      Int      @default(0)
  cost_usd          Float    @default(0)
  response_time_ms  Int      @default(0)
  success           Boolean  @default(true)
  error_message     String?
  created_at        DateTime @default(now())
  user              users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at])
  @@index([action_type])
}
