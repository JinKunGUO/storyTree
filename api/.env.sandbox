# ===================================
# 支付宝沙箱环境配置
# ===================================
# 沙箱环境用于开发测试，无需实际签约即可验证支付流程
# 获取配置：https://open.alipay.com/develop/sandbox/app

# 支付宝网关地址（沙箱环境）
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 沙箱应用 ID（在沙箱控制台获取）
# 格式：20210001xxxxxx
ALIPAY_APP_ID=9021000162625463

# 应用私钥（格式化后的一行，去掉 PEM 标记）
# 在沙箱控制台使用"RSA 密钥 (SHA256)"生成
ALIPAY_PRIVATE_

# 支付宝公钥（格式化后的一行，去掉 PEM 标记）
# 配置应用私钥后，系统自动生成支付宝公钥
ALIPAY_PUBLIC_

# 支付回调通知地址
# 开发环境可以使用 ngrok 暴露到公网
ALIPAY_CALLBACK_URL=http://localhost:3001

# API 基础 URL
API_URL=http://localhost:3001

# ===================================
# 沙箱测试账号（在沙箱控制台获取）
# ===================================
# 买家账号（用于扫码支付测试）
# 登录密码：111111
# 支付密码：111111
SANDBOX_BUYER_EMAIL=jxtthf2503@sandbox.com

# 卖家账号（你的沙箱账号）
# 登录密码：111111
SANDBOX_SELLER_EMAIL=你的沙箱卖家账号

# ===================================
# 其他配置
# ===================================
# 数据库配置
DATABASE_URL="postgresql://postgres:password@localhost:5432/storytree?schema=public"

# JWT 密钥（开发环境）
JWT_SECRET=your-sandbox-jwt-secret-key-change-this

# 环境变量标识
NODE_ENV=development
