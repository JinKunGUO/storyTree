# ===================================
# StoryTree 生产环境配置模板
# ===================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ===================================
# 环境标识
# ===================================
NODE_ENV=production

# ===================================
# 数据库配置（阿里云 RDS MySQL）
# ===================================
# 格式：mysql://用户名:密码@主机:端口/数据库名
# 示例：mysql://root:password123@rm-xxx.mysql.rds.aliyuncs.com:3306/storytree
DATABASE_URL="mysql://username:password@host:3306/storytree"

# ===================================
# 阿里云 OSS 配置（图片存储）
# ===================================
# 在阿里云控制台创建 OSS Bucket 后获取
# https://oss.console.aliyun.com/

# OSS 区域（如：oss-cn-hangzhou）
OSS_REGION=oss-cn-hangzhou

# OSS Bucket 名称
OSS_BUCKET=your-bucket-name

# AccessKey（建议使用 RAM 子账号，仅授予 OSS 权限）
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# OSS 访问域名（可选，配置 CDN 后填写 CDN 域名）
# 不填则使用默认的 OSS 域名
OSS_ENDPOINT=https://your-bucket-name.oss-cn-hangzhou.aliyuncs.com
OSS_CDN_DOMAIN=https://cdn.your-domain.com

# ===================================
# Redis 配置（阿里云 Redis）
# ===================================
# 格式：redis://:密码@主机:端口
# 示例：redis://:password123@r-xxx.redis.rds.aliyuncs.com:6379
REDIS_URL="redis://:password@host:6379"

# ===================================
# JWT 配置
# ===================================
# 生产环境务必使用强密钥（至少 32 位随机字符串）
# 可用命令生成：openssl rand -base64 32
JWT_SECRET=your-production-jwt-secret-at-least-32-chars

# ===================================
# 支付宝配置（生产环境）
# ===================================
# 正式环境网关
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_APP_ID=your-app-id
ALIPAY_PRIVATE_KEY=your-private-key
ALIPAY_PUBLIC_KEY=your-public-key
ALIPAY_CALLBACK_URL=https://api.your-domain.com/api/payment/alipay/callback

# ===================================
# 微信小程序配置
# ===================================
WX_APPID=your-wx-appid
WX_APP_SECRET=your-wx-app-secret
WX_PAY_MCH_ID=your-mch-id
WX_PAY_API_KEY=your-api-key-32chars

# ===================================
# AI 服务配置（通义千问）
# ===================================
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-plus
QWEN_IMAGE_MODEL=wanx-v1

# ===================================
# SMTP 邮件配置
# ===================================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@your-domain.com

# ===================================
# URL 配置
# ===================================
# API 服务地址（用于支付回调等）
API_BASE_URL=https://api.your-domain.com
API_URL=https://api.your-domain.com

# 前端地址（用于邮件中的链接）
FRONTEND_URL=https://your-domain.com

# ===================================
# 存储模式配置
# ===================================
# 存储模式：local（本地磁盘）或 oss（阿里云 OSS）
# 开发环境用 local，生产环境用 oss
STORAGE_MODE=oss

