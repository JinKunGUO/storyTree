# ===================================
# StoryTree 开发环境配置
# ===================================
# 此文件用于本地开发，不要提交到 Git

NODE_ENV=development

# ===================================
# 数据库配置（本地 SQLite）
# ===================================
DATABASE_URL="file:prisma/dev.db"

# ===================================
# 存储模式（开发环境使用本地存储）
# ===================================
STORAGE_MODE=local

# ===================================
# Redis 配置（可选，开发环境可不配置）
# ===================================
# REDIS_URL="redis://localhost:6379"

# ===================================
# JWT 配置
# ===================================
JWT_SECRET=dev-jwt-secret-for-local-development

# ===================================
# 支付宝沙箱配置
# ===================================
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_APP_ID=your-sandbox-app-id
ALIPAY_PRIVATE_KEY=your-sandbox-private-key
ALIPAY_PUBLIC_KEY=your-sandbox-public-key
ALIPAY_CALLBACK_URL=http://localhost:3001

# ===================================
# 微信小程序配置（开发环境）
# ===================================
WX_APPID=your-dev-wx-appid
WX_APP_SECRET=your-dev-wx-app-secret

# ===================================
# AI 服务配置
# ===================================
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-plus
QWEN_IMAGE_MODEL=wanx-v1

# ===================================
# SMTP 邮件配置
# ===================================
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-password
SMTP_FROM=your-email@qq.com

# 开发环境禁用真实邮件发送
DISABLE_EMAIL=true

# ===================================
# URL 配置
# ===================================
API_URL=http://localhost:3001
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001

