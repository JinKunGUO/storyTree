    "doc": "docs"
  },
  "scripts": {
    "test:e2e": "playwright test tests/e2e/smoke/ tests/e2e/crawler/ tests/e2e/flows/ tests/e2e/accessibility/",
    "test:e2e:smoke": "playwright test tests/e2e/smoke/",
    "test:e2e:crawler": "playwright test tests/e2e/crawler/",
    "test:e2e:flows": "playwright test tests/e2e/flows/",
    "test:e2e:visual": "playwright test tests/e2e/visual/",
    "test:e2e:a11y": "playwright test tests/e2e/accessibility/",
    "test:e2e:all": "playwright test",
    "test:e2e:update-snapshots": "playwright test tests/e2e/visual/ --update-snapshots",
    "test:e2e:local": "E2E_BASE_URL=http://localhost:3001 playwright test tests/e2e/smoke/ tests/e2e/crawler/ tests/e2e/flows/ tests/e2e/accessibility/",
    "test:e2e:staging": "E2E_BASE_URL=https://staging.storytree.online playwright test",
    "test:smoke": "bash scripts/smoke-test-production.sh"
  },
  "repository": {
    "type": "git",
