                            <button onclick="showWithdrawalDialog()" style="
                                width: 100%;
                                padding: 12px;
                                background: rgba(255, 255, 255, 0.2);
                                border: 1px solid rgba(255, 255, 255, 0.3);
                                color: white;
                                border-radius: 8px;
                                cursor: pointer;
                                font-size: 16px;
                                font-weight: 600;
                                transition: all 0.3s;
                            " onmouseover="this.style.background='rgba(255,255,255,0.3)'" 
                               onmouseout="this.style.background='rgba(255,255,255,0.2)'">
                                <i class="fas fa-hand-holding-usd"></i> 申请提现
                            </button>
                        </div>

                        <!-- 收益统计 -->
                        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-bottom: 20px;">
                            <div style="
                                padding: 15px;
                                background: #f8f9fa;
                                border-radius: 10px;
                                text-align: center;
                            ">
                                <div style="font-size: 20px; font-weight: 700; color: var(--st-primary-500); margin-bottom: 5px;">
                                    ${data.totalEarnings || 0}
                                </div>
                                <div style="color: #999; font-size: 13px;">总收益</div>
                            </div>
                            <div style="
                                padding: 15px;
                                background: #f8f9fa;
                                border-radius: 10px;
                                text-align: center;
                            ">
                                <div style="font-size: 20px; font-weight: 700; color: #4caf50; margin-bottom: 5px;">
                                    ${data.withdrawnAmount || 0}
                                </div>
                                <div style="color: #999; font-size: 13px;">已提现</div>
                            </div>
                            <div style="
                                padding: 15px;
                                background: #f8f9fa;
                                border-radius: 10px;
                                text-align: center;
                            ">
                                <div style="font-size: 20px; font-weight: 700; color: #ff9800; margin-bottom: 5px;">
                                    ${data.pendingAmount || 0}
                                </div>
                                <div style="color: #999; font-size: 13px;">待审核</div>
                            </div>
                            <div style="
                                padding: 15px;
                                background: #f8f9fa;
                                border-radius: 10px;
                                text-align: center;
                            ">
                                <div style="font-size: 20px; font-weight: 700; color: #2196f3; margin-bottom: 5px;">
                                    ${data.unlockCount || 0}
                                </div>
                                <div style="color: #999; font-size: 13px;">解锁次数</div>
