        // ========== 用户等级相关函数 ==========
        
        // 获取用户等级信息
        function getUserLevelInfo(points) {
            const levels = [
                { level: 1, name: '新手作者', minPoints: 0, maxPoints: 99, quotas: { continuation: 5, polish: 10, illustration: 2 } },
                { level: 2, name: '活跃作者', minPoints: 100, maxPoints: 499, quotas: { continuation: 15, polish: 30, illustration: 5 } },
                { level: 3, name: '专业作者', minPoints: 500, maxPoints: 1999, quotas: { continuation: 30, polish: 60, illustration: 10 } },
                { level: 4, name: '大师作者', minPoints: 2000, maxPoints: Infinity, quotas: { continuation: 50, polish: 100, illustration: 20 } }
            ];
            
            for (const levelInfo of levels) {
                if (points >= levelInfo.minPoints && points <= levelInfo.maxPoints) {
                    // 计算升级进度
                    let progress = 0;
                    let nextLevelPoints = 0;
                    
                    if (levelInfo.level < 4) {
                        // 计算到下一级所需积分
                        const nextLevel = levels[levelInfo.level]; // 数组索引从0开始，level从1开始，所以level正好是下一级的索引
                        nextLevelPoints = nextLevel.minPoints - points;
                        
                        // 计算当前等级的进度百分比
                        const currentLevelRange = levelInfo.maxPoints - levelInfo.minPoints + 1;
                        const currentProgress = points - levelInfo.minPoints;
                        progress = (currentProgress / currentLevelRange) * 100;
                    } else {
                        // 已达最高等级
                        progress = 100;
                        nextLevelPoints = 0;
                    }
                    
                    return {
                        ...levelInfo,
                        progress: Math.min(progress, 100),
                        nextLevelPoints: Math.max(nextLevelPoints, 0)
                    };
                }
            }
            
            return levels[0]; // 默认返回 Lv1
        }
        
        // 更新用户等级显示
        function updateUserLevelDisplay(points) {
            const levelInfo = getUserLevelInfo(points);
            
            console.log('更新用户等级显示:', {
                points,
                currentLevel: levelInfo.level,
                levelName: levelInfo.name,
                nextLevelPoints: levelInfo.nextLevelPoints,
                progress: levelInfo.progress
            });
            
            // 更新用户名旁的等级徽章
            const levelBadgeEl = document.getElementById('userLevelBadge');
            if (levelBadgeEl) {
                levelBadgeEl.textContent = `Lv${levelInfo.level}`;
            }
            
            // 更新等级卡片中的等级图标
            const levelIconEl = document.getElementById('userLevelIcon');
            if (levelIconEl) {
                levelIconEl.textContent = `Lv${levelInfo.level}`;
            }
            
            // 更新等级名称
            const levelNameEl = document.getElementById('levelName');
            if (levelNameEl) {
                levelNameEl.textContent = levelInfo.name;
            }
            
            // 更新升级进度
            const levelProgressTextEl = document.getElementById('levelProgressText');
            if (levelProgressTextEl) {
                if (levelInfo.nextLevelPoints > 0) {
                    // 根据当前等级计算下一级
                    const nextLevel = levelInfo.level + 1;
                    const displayText = `还需 ${levelInfo.nextLevelPoints} 积分升级到 Lv${nextLevel}`;
                    console.log('设置升级进度文本:', displayText);
                    levelProgressTextEl.textContent = displayText;
                } else {
                    levelProgressTextEl.textContent = '🎉 已达最高等级';
                }
            }
        }
        
