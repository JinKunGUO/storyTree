                                            </button>
                                        </div>
                                    </div>
                                `).join('')}
                            </div>
                        </div>

                        <!-- 最近邀请 -->
                        ${invitedUsers && invitedUsers.length > 0 ? `
                            <div style="
                                background: white;
                                border: 2px solid #e9ecef;
                                border-radius: 12px;
                                padding: 20px;
                            ">
                                <h3 style="margin: 0 0 15px 0; color: #333; font-size: 16px;">
                                    <i class="fas fa-user-check"></i> 最近邀请
                                </h3>
                                ${invitedUsers.slice(0, 5).map(user => `
                                    <div style="
                                        display: flex;
                                        align-items: center;
                                        gap: 12px;
                                        padding: 12px;
                                        background: #f8f9fa;
                                        border-radius: 10px;
                                        margin-bottom: 10px;
                                        border: 2px solid transparent;
                                        transition: all 0.3s;
                                    " onmouseover="this.style.borderColor='var(--st-primary-500)'; this.style.background='#fff'" 
                                       onmouseout="this.style.borderColor='transparent'; this.style.background='#f8f9fa'">
                                        <div style="
                                            width: 40px;
                                            height: 40px;
                                            background: linear-gradient(135deg, var(--st-primary-500), var(--st-primary-700));
                                            border-radius: 50%;
                                            display: flex;
                                            align-items: center;
                                            justify-content: center;
                                            color: white;
                                            font-size: 16px;
                                            box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);
                                        ">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div style="flex: 1;">
                                            <div style="font-weight: 600; color: #333; margin-bottom: 2px;">${escapeHtml(user.username)}</div>
                                            <div style="font-size: 12px; color: #999;">
                                                <i class="fas fa-clock"></i> ${formatDate(user.createdAt)}
                                            </div>
                                        </div>
                                        <div style="
                                            padding: 6px 12px;
                                            background: linear-gradient(135deg, #4caf50, #66bb6a);
                                            color: white;
                                            border-radius: 15px;
                                            font-weight: 700;
                                            font-size: 13px;
                                            box-shadow: 0 2px 8px rgba(76, 175, 80, 0.3);
                                        ">+${user.reward || 0}</div>
                                    </div>
                                `).join('')}
                            </div>
                        ` : ''}
                    </div>
                `;
            } catch (error) {
                console.error('加载邀请码错误:', error);
                document.getElementById('invitationSection').innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-exclamation-circle"></i>
                        <p>加载失败</p>
                    </div>
                `;
            }
        }
        
        // 显示生成邀请码对话框
        function showGenerateInviteCodeDialog() {
            const overlay = document.createElement('div');
            overlay.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.5);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10000;
                animation: fadeIn 0.3s;
            `;
            
            overlay.innerHTML = `
                <div style="
                    background: white;
                    border-radius: 20px;
                    padding: 30px;
                    max-width: 500px;
                    width: 90%;
                    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
                    animation: slideUp 0.3s;
                ">
                    <h2 style="margin: 0 0 20px 0; color: #333;">
                        <i class="fas fa-plus-circle" style="color: var(--st-primary-500);"></i> 
                        生成新邀请码
                    </h2>
                    
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; color: #666; font-weight: 600; margin-bottom: 8px;">
                            生成数量
                        </label>
                        <input type="number" id="inviteCodeCount" value="1" min="1" max="100" style="
                            width: 100%;
                            padding: 12px;
                            border: 2px solid #e0e0e0;
                            border-radius: 10px;
                            font-size: 16px;
                            box-sizing: border-box;
                        ">
                    </div>
                    
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; color: #666; font-weight: 600; margin-bottom: 8px;">
                            奖励积分
                        </label>
                        <input type="number" id="inviteCodeBonus" value="50" min="10" max="1000" style="
                            width: 100%;
                            padding: 12px;
                            border: 2px solid #e0e0e0;
                            border-radius: 10px;
                            font-size: 16px;
                            box-sizing: border-box;
                        ">
                    </div>
                    
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; color: #666; font-weight: 600; margin-bottom: 8px;">
                            最大使用次数（-1为无限）
                        </label>
                        <input type="number" id="inviteCodeMaxUses" value="-1" min="-1" style="
                            width: 100%;
                            padding: 12px;
                            border: 2px solid #e0e0e0;
                            border-radius: 10px;
                            font-size: 16px;
                            box-sizing: border-box;
                        ">
                    </div>
                    
                    <div style="margin-bottom: 25px;">
                        <label style="display: block; color: #666; font-weight: 600; margin-bottom: 8px;">
                            有效天数（0为永久）
                        </label>
                        <input type="number" id="inviteCodeExpireDays" value="0" min="0" style="
                            width: 100%;
                            padding: 12px;
                            border: 2px solid #e0e0e0;
                            border-radius: 10px;
                            font-size: 16px;
                            box-sizing: border-box;
                        ">
                    </div>
                    
                    <div style="display: flex; gap: 15px;">
                        <button onclick="this.closest('div').parentElement.parentElement.remove()" style="
                            flex: 1;
                            padding: 12px;
                            background: #f5f5f5;
                            color: #666;
                            border: none;
                            border-radius: 10px;
                            font-size: 16px;
                            font-weight: 600;
                            cursor: pointer;
                        ">取消</button>
                        <button onclick="generateInviteCodes()" style="
                            flex: 1;
                            padding: 12px;
                            background: linear-gradient(135deg, var(--st-primary-500), var(--st-primary-700));
                            color: white;
                            border: none;
                            border-radius: 10px;
                            font-size: 16px;
                            font-weight: 600;
                            cursor: pointer;
                        ">生成</button>
                    </div>
                </div>
            `;
            
            overlay.onclick = (e) => {
                if (e.target === overlay) {
                    overlay.remove();
                }
            };
            
            document.body.appendChild(overlay);
        }
        
        // 生成邀请码
        async function generateInviteCodes() {
            const count = parseInt(document.getElementById('inviteCodeCount').value);
            const bonusPoints = parseInt(document.getElementById('inviteCodeBonus').value);
            const maxUses = parseInt(document.getElementById('inviteCodeMaxUses').value);
            const expiresInDays = parseInt(document.getElementById('inviteCodeExpireDays').value);
            
            if (!count || count < 1) {
                window.toast ? toast.warning('请输入有效的生成数量') : alert('请输入有效的生成数量');
                return;
            }
            
            if (!bonusPoints || bonusPoints < 10) {
                window.toast ? toast.warning('奖励积分不能少于10') : alert('奖励积分不能少于10');
                return;
            }
            
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/invitations/admin/generate', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        count,
                        bonusPoints,
                        maxUses,
                        expiresInDays
                    })
                });
                
                const data = await response.json();
                
                // 移除对话框
                document.querySelectorAll('body > div').forEach(div => {
                    if (div.style.position === 'fixed') {
                        div.remove();
                    }
                });
                
                if (response.ok) {
                    window.toast ? toast.success(`成功生成 ${data.count} 个邀请码！`) : alert(`✅ 成功生成 ${data.count} 个邀请码！`);
                    // 刷新邀请码列表
                    await loadInvitationCodes();
                } else {
                    window.toast ? toast.error(data.error || '生成邀请码失败') : alert('❌ ' + (data.error || '生成邀请码失败'));
                }
            } catch (error) {
                console.error('生成邀请码失败:', error);
                window.toast ? toast.error('生成失败，请稍后重试') : alert('生成失败，请稍后重试');
            }
        }

        // 复制邀请码
        function copyInviteCode(code) {
            const text = `${code} - 来StoryTree一起创作故事吧！注册时输入这个邀请码可以获得额外积分奖励哦~`;
            
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(() => {
                    window.toast ? toast.success('邀请码已复制到剪贴板！') : alert('邀请码已复制到剪贴板！');
                }).catch(() => {
                    fallbackCopy(text);
                });
            } else {
                fallbackCopy(text);
            }
        }

        // 备用复制方法
        function fallbackCopy(text) {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand('copy');
                window.toast ? toast.success('邀请码已复制到剪贴板！') : alert('邀请码已复制到剪贴板！');
            } catch (err) {
                window.toast ? toast.error('复制失败，请手动复制邀请码') : alert('复制失败，请手动复制邀请码');
            }
            document.body.removeChild(textarea);
        }

        // 分享邀请码
        function shareInviteCode(code) {
            const url = `${window.location.origin}/register?invite=${code}`;
            const text = `来StoryTree一起创作故事吧！使用我的邀请码 ${code} 注册可以获得额外积分奖励哦~`;
            
            if (navigator.share) {
                navigator.share({
                    title: 'StoryTree邀请码',
                    text: text,
                    url: url
                }).catch(err => {
                    console.log('分享取消或失败:', err);
                });
            } else {
                copyInviteCode(code);
            }
        }

        // ========== 收益管理系统（代码保留，前端展示已暂时隐藏，功能即将开放） ==========
        
