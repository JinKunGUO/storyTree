// 获取徽章显示 HTML
        function getBadgeDisplay(badgeId) {
            const badgeMap = {
                'rookie': { emoji: '🌱', name: '初出茅庐', color: '#4caf50' },
                'achiever': { emoji: '📝', name: '小有成就', color: '#2196f3' },
                'diligent': { emoji: '✍️', name: '笔耕不辍', color: '#9c27b0' },
                'professional': { emoji: '📚', name: '专业作者', color: '#ff9800' },
                'signed': { emoji: '🎖️', name: '签约作者', color: '#f44336' },
                'master': { emoji: '👑', name: '大神作者', color: '#ffd700' },
                'legend': { emoji: '🏆', name: '殿堂作者', color: '#e91e63' }
            };
            
            const badge = badgeMap[badgeId];
            if (!badge) return '';
            
            return `
                <span class="badge-display" style="
                    display: inline-flex;
                    align-items: center;
                    gap: 5px;
                    padding: 4px 12px;
                    background: ${badge.color};
                    color: white;
                    border-radius: 15px;
                    font-size: 13px;
                    font-weight: 600;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
                " title="${badge.name}">
                    <span style="font-size: 16px;">${badge.emoji}</span>
                    <span>${badge.name}</span>
                </span>
            `;
        }

        // 显示积分明细弹窗
        async function showPointsHistory() {
            const token = localStorage.getItem('token') || sessionStorage.getItem('token');
            if (!token) {
                showMessage('请先登录', 'error');
                return;
            }

            // 创建弹窗
            const overlay = document.createElement('div');
            overlay.id = 'pointsHistoryOverlay';
            overlay.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.5);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10000;
                animation: fadeIn 0.3s;
            `;

            overlay.innerHTML = `
                <div style="
                    background: white;
                    border-radius: 20px;
                    padding: 30px;
                    max-width: 800px;
                    width: 90%;
                    max-height: 80vh;
                    overflow-y: auto;
                    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
                    animation: slideUp 0.3s;
                ">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h2 style="margin: 0; color: #333;">
                            <i class="fas fa-list-alt" style="color: var(--st-primary-500);"></i> 
                            积分明细
                        </h2>
                        <button onclick="document.getElementById('pointsHistoryOverlay').remove()" style="
                            background: none;
                            border: none;
                            font-size: 24px;
                            cursor: pointer;
                            color: #999;
                            padding: 0;
                            width: 32px;
                            height: 32px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            border-radius: 50%;
                            transition: all 0.3s;
                        " onmouseover="this.style.background='#f0f0f0'; this.style.color='#333';" 
                           onmouseout="this.style.background='none'; this.style.color='#999';">
                            ×
                        </button>
                    </div>
                    
                    <div id="pointsHistoryContent" style="text-align: center; padding: 40px;">
                        <div style="display: inline-block; width: 40px; height: 40px; border: 4px solid #f0f0f0; border-top-color: var(--st-primary-500); border-radius: 50%; animation: spin 1s linear infinite;"></div>
                        <p style="margin-top: 15px; color: #999;">加载中...</p>
                    </div>
                </div>
            `;

            overlay.onclick = (e) => {
                if (e.target === overlay) {
                    overlay.remove();
                }
            };

            document.body.appendChild(overlay);

            // 加载积分明细
            try {
                // 先加载所有记录用于统计，再加载 50 条用于显示
                const [allTransactionsResponse, recentTransactionsResponse] = await Promise.all([
                    fetch('/api/points/transactions?page=1&limit=1000', {
                        headers: {
                            'Authorization': `Bearer ${token}`
                        }
                    }),
                    fetch('/api/points/transactions?page=1&limit=50', {
                        headers: {
                            'Authorization': `Bearer ${token}`
                        }
                    })
                ]);

                if (!allTransactionsResponse.ok || !recentTransactionsResponse.ok) {
                    throw new Error('加载失败');
                }

                const allData = await allTransactionsResponse.json();
                const recentData = await recentTransactionsResponse.json();
                
                const allTransactions = allData.transactions || [];
                const transactions = recentData.transactions || [];

                const contentDiv = document.getElementById('pointsHistoryContent');
                
                if (transactions.length === 0) {
                    contentDiv.innerHTML = `
                        <div style="text-align: center; padding: 40px;">
                            <i class="fas fa-inbox" style="font-size: 48px; color: #ccc; margin-bottom: 15px;"></i>
                            <p style="color: #999;">暂无积分记录</p>
                        </div>
                    `;
                    return;
                }

                // 使用所有记录进行统计（而不是仅用前 50 条）
                const summary = {};
                allTransactions.forEach(t => {
                    const typeConfig = getPointsTypeConfig(t.type);
                    const displayName = typeConfig.name; // 使用显示名称作为 key
                    
                    if (!summary[displayName]) {
                        summary[displayName] = {
                            amount: 0,
                            icon: typeConfig.icon,
                            color: typeConfig.color
                        };
                    }
                    summary[displayName].amount += t.amount;
                });

                // 生成明细列表
                const rows = transactions.map(t => {
                    const typeConfig = getPointsTypeConfig(t.type);
                    const isPositive = t.amount > 0;
                    const time = new Date(t.createdAt).toLocaleString('zh-CN');
                    
                    // 显示来源信息
                    let sourceInfo = '';
                    if (t.sourceInfo) {
                        if (t.sourceInfo.type === 'node') {
                            sourceInfo = `
                                <div style="font-size: 13px; color: #666; margin-top: 4px;">
                                    📖 ${t.sourceInfo.storyTitle} - ${t.sourceInfo.title}
                                </div>
                            `;
                        } else if (t.sourceInfo.type === 'story') {
                            sourceInfo = `
                                <div style="font-size: 13px; color: #666; margin-top: 4px;">
                                    📚 ${t.sourceInfo.title}
                                </div>
                            `;
                        }
                    }
                    
                    return `
                        <div style="
                            display: flex;
                            align-items: center;
                            justify-content: space-between;
                            padding: 15px 20px;
                            border-bottom: 1px solid #f0f0f0;
                            transition: background 0.3s;
                            min-height: 70px;
                        " onmouseover="this.style.background='#f9f9f9'" onmouseout="this.style.background='white'">
                            <div style="
                                display: flex;
                                align-items: center;
                                gap: 15px;
                                flex: 1;
                            ">
                                <span style="
                                    width: 40px;
                                    height: 40px;
                                    border-radius: 50%;
                                    background: ${typeConfig.color};
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    color: white;
                                    font-size: 18px;
                                    flex-shrink: 0;
                                ">${typeConfig.icon}</span>
                                <div style="flex: 1; min-width: 0;">
                                    <div style="font-weight: 600; color: #333; margin-bottom: 4px;">${typeConfig.name}</div>
                                    <div style="font-size: 12px; color: #999;">${time}</div>
                                    ${sourceInfo}
                                </div>
                            </div>
                            <div style="text-align: right; flex-shrink: 0; margin-left: 20px;">
                                <div style="
                                    font-size: 20px;
                                    font-weight: 700;
                                    color: ${isPositive ? '#4caf50' : '#f44336'};
                                ">${isPositive ? '+' : ''}${t.amount}</div>
                            </div>
                        </div>
                    `;
                }).join('');

                // 计算总分
                const totalPoints = Object.values(summary).reduce((sum, data) => sum + data.amount, 0);
                
                contentDiv.innerHTML = `
                    <div style="margin-bottom: 20px; padding: 15px; background: #f8f9fa; border-radius: 10px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <div style="font-size: 12px; color: #999;">
                                <i class="fas fa-chart-pie"></i> 积分统计
                            </div>
                            <div style="font-size: 14px; font-weight: 600; color: #333;">
                                总计：<span style="color: #4caf50;">+${totalPoints.toLocaleString()}</span> 积分
                            </div>
                        </div>
                        <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                            ${Object.entries(summary).map(([name, data]) => {
                                const isPositive = data.amount > 0;
                                return `
                                    <div style="flex: 1; min-width: 120px; text-align: center;">
                                        <div style="font-size: 12px; color: #999; margin-bottom: 5px; display: flex; align-items: center; justify-content: center; gap: 5px;">
                                            <span style="width: 16px; height: 16px; border-radius: 50%; background: ${data.color}; display: inline-flex; align-items: center; justify-content: center; color: white; font-size: 10px;">${data.icon}</span>
                                            ${name}
                                        </div>
                                        <div style="font-size: 18px; font-weight: 700; color: ${isPositive ? '#4caf50' : '#f44336'};">
                                            ${isPositive ? '+' : ''}${data.amount}
                                        </div>
                                    </div>
                                `;
                            }).join('')}
                        </div>
                    </div>
                    <div style="border: 1px solid #f0f0f0; border-radius: 10px; overflow: hidden;">
                        ${rows}
                    </div>
                `;
            } catch (error) {
                console.error('加载积分明细错误:', error);
                const contentDiv = document.getElementById('pointsHistoryContent');
                contentDiv.innerHTML = `
                    <div style="text-align: center; padding: 40px;">
                        <i class="fas fa-exclamation-triangle" style="font-size: 48px; color: #f44336; margin-bottom: 15px;"></i>
                        <p style="color: #999;">加载失败，请稍后重试</p>
                    </div>
                `;
            }
        }

        // 获取积分类型配置
        function getPointsTypeConfig(type) {
            const config = {
                // 签到相关
                'checkin': { name: '签到奖励', icon: '📅', color: '#4caf50' },
                'daily_checkin': { name: '签到奖励', icon: '📅', color: '#4caf50' },
                'checkin_milestone': { name: '签到里程碑', icon: '🏆', color: '#ff9800' },
                
                // 创作相关
                'word_count': { name: '码字奖励', icon: '✍️', color: '#2196f3' },
                'publish_story': { name: '发布故事', icon: '📚', color: '#9c27b0' },
                'publish_node': { name: '发布章节', icon: '📝', color: '#673ab7' },
                
                // 社交互动
                'bookmark': { name: '获得收藏', icon: '⭐', color: '#ff5722' },
                'bookmark_node': { name: '获得收藏', icon: '⭐', color: '#ff5722' },
                'like': { name: '获得点赞', icon: '👍', color: '#e91e63' },
                
                // 邀请相关
                'invite': { name: '邀请奖励', icon: '🎁', color: '#00bcd4' },
                'invited': { name: '被邀请奖励', icon: '🎉', color: '#8bc34a' },
                
                // AI 功能
                'ai_continuation': { name: 'AI 续写', icon: '🤖', color: '#607d8b' },
                'ai_polish': { name: 'AI 润色', icon: '✨', color: '#795548' },
                'ai_illustration': { name: 'AI 插图', icon: '🎨', color: '#3f51b5' },
                
                // 置顶功能
                'pin_story': { name: '置顶故事', icon: '📌', color: '#f44336' },
                'pin_comment': { name: '置顶评论', icon: '📍', color: '#e91e63' },
                
                // 会员相关
                'membership': { name: '购买会员', icon: '👑', color: '#ffd700' },
                
                // 里程碑
                'milestone': { name: '里程碑奖励', icon: '🎯', color: '#ff4081' },
                
                // 其他
                'other': { name: '其他', icon: '📝', color: '#9e9e9e' }
            };
            
            // 如果找到匹配的类型，直接返回
            if (config[type]) {
                return config[type];
            }
            
            // 尝试模糊匹配
            const typeStr = String(type).toLowerCase();
            for (const key in config) {
                if (key !== 'other' && typeStr.includes(key)) {
                    return config[key];
                }
            }
            
            // 默认返回 other
            return config.other;
        }

        // 加载用户统计
        async function loadUserStats(userId) {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                console.log('开始加载用户统计, userId:', userId);
                
                // 使用 /api/users/:id 获取用户信息（包含_count）
                const response = await fetch(`/api/users/${userId}`, {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                console.log('用户统计API响应状态:', response.status);

                if (!response.ok) {
                    console.error('加载用户统计失败:', response.status);
                    return;
                }
                
                const data = await response.json();
                console.log('用户统计数据:', data);
                
                // 从_count中提取统计数据（注意：后端返回的是authored_stories和authored_nodes）
                const storyCount = data.user?._count?.authored_stories || 0;
                const nodeCount = data.user?._count?.authored_nodes || 0;
                
                document.getElementById('storyCount').textContent = storyCount;
                document.getElementById('nodeCount').textContent = nodeCount;
                
                // 点赞数和浏览量会在loadUserStories中更新
                document.getElementById('likeCount').textContent = 0;
                document.getElementById('viewCount').textContent = 0;
            } catch (error) {
                console.error('加载统计数据错误:', error);
            }
        }

        // 加载用户故事
        async function loadUserStories(userId) {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                console.log('开始加载用户故事, userId:', userId);
                console.log('请求 /api/users/' + userId + '/stories');
                
                const response = await fetch(`/api/users/${userId}/stories`, {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                console.log('故事API响应状态:', response.status);
                console.log('故事API响应Content-Type:', response.headers.get('content-type'));

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('故事API错误响应:', errorText);
                    throw new Error('加载故事失败: ' + response.status);
                }

                const data = await response.json();
                console.log('故事API返回数据:', data);
                console.log('故事数量:', data.stories?.length || 0);
                
                displayUserStories(data.stories);
            } catch (error) {
                console.error('加载故事错误:', error);
                showEmptyStories();
            }
        }

        // 显示用户故事
        function displayUserStories(stories) {
            const storiesList = document.getElementById('storiesList');
            
            console.log('收到的故事数据:', stories);
            
            if (!stories || stories.length === 0) {
                showEmptyStories();
                return;
            }

            // 计算总的点赞数和浏览量
            let totalLikes = 0;
            let totalViews = 0;

            const storiesHTML = stories.map(story => {
                // 安全地获取章节数
                const nodeCount = story._count?.nodes || 0;
                
                // 获取点赞数（bookmarks）和浏览量
                const likeCount = story.likes || story._count?.bookmarks || 0;
                const viewCount = story.views || 0;
                
                // 累加到总数
                totalLikes += likeCount;
                totalViews += viewCount;
                
                return `
                    <div class="story-item" onclick="window.location.href='/story?id=${story.id}'">
                        <div class="story-icon">
                            <i class="fas fa-book-open"></i>
                        </div>
                        <div class="story-details">
                            <div class="story-title">${escapeHtml(story.title)}</div>
                            <div class="story-meta">
                                <span><i class="fas fa-file-alt"></i> ${nodeCount} 章节</span>
                                <span><i class="fas fa-heart"></i> ${likeCount} 点赞</span>
                                <span><i class="fas fa-eye"></i> ${viewCount} 浏览</span>
                                <span><i class="fas fa-clock"></i> ${formatDate(story.updated_at || story.createdAt)}</span>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            storiesList.innerHTML = storiesHTML;
            
            // 更新统计卡片中的总点赞数和总浏览量
            const likeCountElement = document.getElementById('likeCount');
            if (likeCountElement) {
                likeCountElement.textContent = totalLikes;
            }
            
            const viewCountElement = document.getElementById('viewCount');
            if (viewCountElement) {
                viewCountElement.textContent = totalViews;
            }
            
            console.log('统计更新 - 总点赞:', totalLikes, '总浏览:', totalViews);
        }

        // 显示空状态
        function showEmptyStories() {
            const storiesList = document.getElementById('storiesList');
            storiesList.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-book"></i>
                    <p>还没有创作任何故事</p>
                    <a href="/create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> 创建第一个故事
                    </a>
                </div>
            `;
        }

        // HTML转义
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // 格式化日期
        function formatDate(dateString) {
            if (!dateString) return '未知时间';
            
            const date = new Date(dateString);
            
            // 检查日期是否有效
            if (isNaN(date.getTime())) {
                console.warn('无效的日期:', dateString);
                return '未知时间';
            }
            
            const now = new Date();
            const diff = now - date;
            
            // 如果是未来时间，显示完整日期
            if (diff < 0) {
                return date.toLocaleDateString('zh-CN');
            }
            
            const minutes = Math.floor(diff / 60000);
            const hours = Math.floor(diff / 3600000);
            const days = Math.floor(diff / 86400000);
            
            if (minutes < 1) return '刚刚';
            if (minutes < 60) return `${minutes}分钟前`;
            if (hours < 24) return `${hours}小时前`;
            if (days < 30) return `${days}天前`;
            
            return date.toLocaleDateString('zh-CN');
        }

        // 加载关注的故事
        async function loadFollowedStories(userId) {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                // 1. 获取追更故事
                const followedResponse = await fetch(`/api/stories/user/${userId}/followed-stories`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (!followedResponse.ok) {
                    throw new Error('加载关注的故事失败');
                }
                
                const followedData = await followedResponse.json();
                
                // 2. 获取协作故事
                const collaboratedResponse = await fetch(`/api/users/${userId}/collaborated-stories`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                let collaboratedStories = [];
                if (collaboratedResponse.ok) {
                    const collaboratedData = await collaboratedResponse.json();
                    collaboratedStories = collaboratedData.stories || [];
                }
                
                // 3. 合并和标记
                const followedStories = (followedData.follows || []).map(f => ({
                    ...f.story,
                    is_collaborated: false,
                    is_followed: true
                }));
                
                // 标记协作故事
                const storyMap = new Map();
                followedStories.forEach(story => {
                    storyMap.set(story.id, story);
                });
                
                collaboratedStories.forEach(story => {
                    if (storyMap.has(story.id)) {
                        // 已存在，标记为协作
                        storyMap.get(story.id).is_collaborated = true;
                    } else {
                        // 新增协作故事
                        storyMap.set(story.id, {
                            ...story,
                            is_collaborated: true,
                            is_followed: false
                        });
                    }
                });
                
                // 4. 转换为数组并排序
                const allStories = Array.from(storyMap.values());
                allStories.sort((a, b) => {
                    // 协作故事优先
                    if (a.is_collaborated && !b.is_collaborated) return -1;
                    if (!a.is_collaborated && b.is_collaborated) return 1;
                    // 按更新时间排序
                    return new Date(b.updated_at || b.createdAt) - new Date(a.updated_at || a.createdAt);
                });
                
                displayFollowedStories(allStories);
            } catch (error) {
                console.error('加载关注的故事错误:', error);
                showEmptyFollowedStories();
            }
        }

        // 显示关注的故事
        function displayFollowedStories(stories) {
            const list = document.getElementById('followedStoriesList');
            
            if (!stories || stories.length === 0) {
                showEmptyFollowedStories();
                return;
            }

            const storiesHTML = stories.map(story => {
                const nodeCount = story._count?.nodes || 0;
                const followerCount = story._count?.followers || 0;
                const viewCount = story.views || 0;
                const authorName = story.author?.username || '未知作者';
                
                // 确定图标和标签
                let icon, badge, badgeClass, iconClass;
                if (story.is_collaborated) {
                    icon = 'fa-users';
                    badge = '协作中';
                    badgeClass = 'badge-collaborated';
                    iconClass = 'icon-collaborated';
                } else {
                    icon = 'fa-star';
                    badge = '追更中';
                    badgeClass = 'badge-followed';
                    iconClass = 'icon-followed';
                }
                
                return `
                    <div class="story-item" onclick="window.location.href='/story?id=${story.id}'" style="cursor: pointer;">
                        <div class="story-icon ${iconClass}">
                            <i class="fas ${icon}"></i>
                        </div>
                        <div class="story-details">
                            <div class="story-title">
                                ${escapeHtml(story.title)}
                                <span class="story-badge ${badgeClass}">${badge}</span>
                            </div>
                            <div class="story-meta">
                                <span><i class="fas fa-user"></i> ${escapeHtml(authorName)}</span>
                                <span><i class="fas fa-file-alt"></i> ${nodeCount} 章节</span>
                                <span><i class="fas fa-book-reader"></i> ${followerCount} 追更</span>
                                <span><i class="fas fa-eye"></i> ${viewCount} 浏览</span>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            list.innerHTML = storiesHTML;
        }
        
        // 显示消息提示
        function showMessage(message, type = 'info') {
            // 优先使用 toast 组件
            if (window.toast) {
                if (type === 'error') toast.error(message);
                else if (type === 'success') toast.success(message);
                else toast.info(message);
                return;
            }
            // 降级：内联消息提示
            const messageEl = document.createElement('div');
            messageEl.style.cssText = `
                position: fixed;
                top: 80px;
                right: 20px;
                background: white;
                padding: 15px 25px;
                border-radius: 10px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.2);
                display: flex;
                align-items: center;
                gap: 10px;
                z-index: 10000;
                border-left: 4px solid ${type === 'error' ? '#f44336' : '#4caf50'};
                animation: slideIn 0.3s ease-out;
            `;

            messageEl.innerHTML = `
                <i class="fas fa-${type === 'error' ? 'exclamation-circle' : 'check-circle'}"></i>
                <span>${message}</span>
            `;

            document.body.appendChild(messageEl);

            setTimeout(() => {
                messageEl.style.animation = 'fadeOut 0.3s ease-out forwards';
                setTimeout(() => messageEl.remove(), 300);
            }, 3000);
        }

        // 显示空的关注列表
        function showEmptyFollowedStories() {
            const list = document.getElementById('followedStoriesList');
            list.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-star"></i>
                    <p>还没有关注任何故事</p>
                    <a href="/discover" class="btn btn-primary">
                        <i class="fas fa-search"></i> 去发现故事
                    </a>
                </div>
            `;
        }

        // 加载协作申请
        async function loadCollaborationRequests(userId) {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/collaboration-requests/my-requests', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (!response.ok) {
                    throw new Error('加载协作申请失败');
                }

                const data = await response.json();
                displayCollaborationRequests(data.requests);
            } catch (error) {
                console.error('加载协作申请错误:', error);
                showEmptyRequests();
            }
        }

        // 显示协作申请列表
        function displayCollaborationRequests(requests) {
            const list = document.getElementById('collaborationRequestsList');
            
            if (!requests || requests.length === 0) {
                showEmptyRequests();
                return;
            }

            const requestsHTML = requests.map(request => {
                const statusClass = request.status.toLowerCase();
                const statusText = {
                    'pending': '待审核',
                    'approved': '已通过',
                    'rejected': '已拒绝'
                }[request.status.toLowerCase()] || request.status;
                
                return `
                    <div class="request-item ${statusClass}">
                        <div class="request-info">
                            <div class="request-story">
                                ${escapeHtml(request.story.title)}
                            </div>
                            <div class="request-message">
                                申请留言: ${escapeHtml(request.message || '无')}
                            </div>
                            <div class="request-meta">
                                <span><i class="fas fa-clock"></i> ${formatDate(request.created_at)}</span>
                                <span class="request-status status-${statusClass}">
                                    ${statusText}
                                </span>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            list.innerHTML = requestsHTML;
        }

        // 显示空的申请列表
        function showEmptyRequests() {
            const list = document.getElementById('collaborationRequestsList');
            list.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-user-plus"></i>
                    <p>还没有提交任何协作申请</p>
                </div>
            `;
        }

        // 加载通知未读数
        async function loadNotificationCount() {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/notifications', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (!response.ok) {
                    console.error('加载通知失败');
                    return;
                }

                const data = await response.json();
                const unreadCount = data.unreadCount || 0;
                
                const badge = document.getElementById('notificationBadge');
                if (unreadCount > 0) {
                    badge.textContent = unreadCount > 99 ? '99+' : unreadCount;
                    badge.style.display = 'block';
                } else {
                    badge.style.display = 'none';
                }
            } catch (error) {
                console.error('加载通知数量错误:', error);
            }
        }

        // 加载粉丝列表
        async function loadFollowers(userId) {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch(`/api/users/${userId}/followers`, {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (!response.ok) {
                    throw new Error('加载粉丝列表失败');
                }

                const data = await response.json();
                allFollowers = data.followers || []; // 存储完整数据
                displayFollowers();
            } catch (error) {
                console.error('加载粉丝列表错误:', error);
                showEmptyFollowers();
            }
        }

        // 显示粉丝列表
        function displayFollowers() {
            const list = document.getElementById('followersList');
            const viewMoreBtn = document.getElementById('viewMoreFollowers');
            
            if (!allFollowers || allFollowers.length === 0) {
                showEmptyFollowers();
                viewMoreBtn.style.display = 'none';
                return;
            }

            // 根据展开状态决定显示数量
            const displayItems = isFollowersExpanded ? allFollowers : allFollowers.slice(0, MAX_COMPACT_ITEMS);
            
            const followersHTML = displayItems.map(follower => {
                const followersCount = follower._count?.followers || 0;
                return `
                    <div class="story-item" onclick="window.location.href='/profile.html?id=${follower.id}'">
                        <div class="story-icon" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
                            <i class="fas fa-user"></i>
                        </div>
                        <div class="story-details">
                            <div class="story-title">${escapeHtml(follower.username)}</div>
                            <div class="story-meta">
                                <span><i class="fas fa-users"></i> ${followersCount} 粉丝</span>
                                <span><i class="fas fa-clock"></i> ${formatDate(follower.followedAt)}</span>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            list.innerHTML = followersHTML;

            // 控制"查看全部"按钮显示
            if (allFollowers.length > MAX_COMPACT_ITEMS) {
                viewMoreBtn.style.display = 'block';
                viewMoreBtn.textContent = isFollowersExpanded ? '收起' : `查看全部 (${allFollowers.length})`;
            } else {
                viewMoreBtn.style.display = 'none';
            }
        }

        // 切换粉丝列表展开/收起
        function toggleFollowersView() {
            isFollowersExpanded = !isFollowersExpanded;
            displayFollowers();
            
            // 如果收起，滚动到列表顶部
            if (!isFollowersExpanded) {
                document.getElementById('followersList').scrollTop = 0;
            }
        }

        // 显示空的粉丝列表
        function showEmptyFollowers() {
            const list = document.getElementById('followersList');
            list.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-users"></i>
                    <p>还没有粉丝</p>
                    <p style="color: #999; font-size: 14px;">多创作优质内容，吸引更多粉丝关注吧！</p>
                </div>
            `;
        }

        // 加载故事追更者列表
        async function loadStoryFollowers(userId) {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                // 获取用户的所有故事
                const storiesResponse = await fetch(`/api/users/${userId}/stories`, {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (!storiesResponse.ok) {
                    throw new Error('加载故事失败');
                }

                const storiesData = await storiesResponse.json();
                const stories = storiesData.stories || [];

                // 为每个故事获取追更者
                const storyFollowersData = [];
                for (const story of stories) {
                    const followersResponse = await fetch(`/api/stories/${story.id}/followers`, {
                        headers: {
                            'Authorization': `Bearer ${token}`
                        }
                    });

                    if (followersResponse.ok) {
                        const followersData = await followersResponse.json();
                        if (followersData.followers && followersData.followers.length > 0) {
                            storyFollowersData.push({
                                story: story,
                                followers: followersData.followers,
                                total: followersData.pagination?.total || followersData.followers.length
                            });
                        }
                    }
                }

                allStoryFollowers = storyFollowersData; // 存储完整数据
                displayStoryFollowers();
            } catch (error) {
                console.error('加载故事追更者错误:', error);
                showEmptyStoryFollowers();
            }
        }

        // 显示故事追更者列表
        function displayStoryFollowers() {
            const list = document.getElementById('storyFollowersList');
            const viewMoreBtn = document.getElementById('viewMoreStoryFollowers');
            
            if (!allStoryFollowers || allStoryFollowers.length === 0) {
                showEmptyStoryFollowers();
                viewMoreBtn.style.display = 'none';
                return;
            }

            // 根据展开状态决定显示数量
            const displayItems = isStoryFollowersExpanded ? allStoryFollowers : allStoryFollowers.slice(0, MAX_COMPACT_ITEMS);

            const html = displayItems.map(item => {
                const followersPreview = item.followers.slice(0, 5).map(f => 
                    escapeHtml(f.user.username)
                ).join('、');
                
                const moreText = item.total > 5 ? ` 等${item.total}人` : '';
                
                return `
                    <div class="story-item" onclick="window.location.href='/story.html?id=${item.story.id}'">
                        <div class="story-icon" style="background: linear-gradient(135deg, var(--st-primary-500), var(--st-primary-700));">
                            <i class="fas fa-book"></i>
                        </div>
                        <div class="story-details">
                            <div class="story-title">
                                ${escapeHtml(item.story.title)}
                                <span class="story-badge badge-followed">${item.total} 人追更</span>
                            </div>
                            <div class="story-meta" style="color: #666;">
                                <span><i class="fas fa-users"></i> ${followersPreview}${moreText}</span>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            list.innerHTML = html;

            // 控制"查看全部"按钮显示
            if (allStoryFollowers.length > MAX_COMPACT_ITEMS) {
                viewMoreBtn.style.display = 'block';
                viewMoreBtn.textContent = isStoryFollowersExpanded ? '收起' : `查看全部 (${allStoryFollowers.length})`;
            } else {
                viewMoreBtn.style.display = 'none';
            }
        }

        // 切换故事追更者列表展开/收起
        function toggleStoryFollowersView() {
            isStoryFollowersExpanded = !isStoryFollowersExpanded;
            displayStoryFollowers();
            
            // 如果收起，滚动到列表顶部
            if (!isStoryFollowersExpanded) {
                document.getElementById('storyFollowersList').scrollTop = 0;
            }
        }

        // 显示空的故事追更者列表
        function showEmptyStoryFollowers() {
            const list = document.getElementById('storyFollowersList');
            list.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-book-reader"></i>
                    <p>还没有人追更你的故事</p>
                    <p style="color: #999; font-size: 14px;">继续创作精彩内容，吸引读者追更吧！</p>
                </div>
            `;
        }
        
        // 兑换邀请码
        async function redeemInviteCode() {
            const codeInput = document.getElementById('inviteCodeInput');
            const messageDiv = document.getElementById('redeemMessage');
            const code = codeInput.value.trim().toUpperCase();
            
            if (!code) {
                messageDiv.innerHTML = '<span style="color: #f44336;"><i class="fas fa-exclamation-circle"></i> 请输入邀请码</span>';
                return;
            }
            
            if (code.length !== 8) {
                messageDiv.innerHTML = '<span style="color: #f44336;"><i class="fas fa-exclamation-circle"></i> 邀请码必须是 8 位</span>';
                return;
            }
            
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                messageDiv.innerHTML = '<span style="color: #2196f3;"><i class="fas fa-spinner fa-spin"></i> 正在兑换...</span>';
                
                const response = await fetch('/api/invitations/redeem', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ code })
                });
                
                const data = await response.json();
                
                if (response.ok && data.success) {
                    messageDiv.innerHTML = `
                        <span style="color: #4caf50;">
                            <i class="fas fa-check-circle"></i> 
                            兑换成功！获得 <strong>${data.bonusPoints}</strong> 积分
                            ${data.inviterBonus > 0 ? `（邀请人获得 ${data.inviterBonus} 积分）` : ''}
                        </span>
                    `;
                    codeInput.value = '';
                    
                    // 重新加载用户信息和邀请码
                    setTimeout(() => {
                        loadUserProfile();
                        loadInvitationCodes();
                    }, 1000);
                } else {
                    messageDiv.innerHTML = `<span style="color: #f44336;"><i class="fas fa-exclamation-circle"></i> ${data.error || '兑换失败'}</span>`;
                }
            } catch (error) {
                console.error('兑换邀请码错误:', error);
                messageDiv.innerHTML = '<span style="color: #f44336;"><i class="fas fa-exclamation-circle"></i> 兑换失败，请稍后重试</span>';
            }
        }
        
// ========== 邀请码系统 ==========
        
        // 加载邀请码
        async function loadInvitationCodes() {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/invitations/my-codes', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                const invitationSection = document.getElementById('invitationSection');

                if (!response.ok) {
                    invitationSection.innerHTML = `
                        <div class="empty-state">
                            <i class="fas fa-lock"></i>
                            <p>暂无邀请码权限</p>
                            <p style="color: #999; font-size: 14px;">满足以下任一条件即可获得邀请码权限：</p>
                            <ul style="text-align: left; margin-top: 15px; padding-left: 20px; color: #666;">
                                <li>📝 创作满 <strong>1 万字</strong></li>
                                <li>📅 连续签到 <strong>7 天</strong></li>
                                <li>📚 发布 1 个故事且章节数 <strong>≥ 3 章</strong></li>
                                <li>🎖️ 管理员直接授予</li>
                            </ul>
                        </div>
                    `;
                    return;
                }

                const data = await response.json();
                
                // 适配后端 API 返回的数据结构
                const codes = data.codes || [];
                const invitationCode = data.invitationCode;
                const canGenerate = data.canGenerate;
                const totalInvites = data.totalInvites || 0;
                const totalRewards = data.totalRewards || 0;
                const inviteRecords = data.inviteRecords || [];
                
if (codes.length === 0) {
                    invitationSection.innerHTML = `
                        <div class="empty-state">
                            <i class="fas fa-gift"></i>
                            <p>暂无邀请码</p>
                            <p style="color: #999; font-size: 14px;">满足条件后将自动生成邀请码：</p>
                            <ul style="text-align: left; margin-top: 15px; padding-left: 20px; color: #666;">
                                <li>📝 创作满 <strong>1 万字</strong></li>
                                <li>📅 连续签到 <strong>7 天</strong></li>
                                <li>📚 发布 1 个故事且章节数 <strong>≥ 3 章</strong></li>
                                <li>🎖️ 管理员直接授予</li>
                            </ul>
                        </div>
                    `;
                    return;
                }
                
                // 构建邀请用户列表
                const invitedUsers = inviteRecords.map(record => ({
                    username: record.inviteeUsername,
                    wordCount: record.inviteeWordCount,
                    reward: record.bonusPoints,
                    createdAt: record.invitedAt
                }));
                
                // 统计数据
                const stats = {
                    totalInvited: totalInvites,
                    totalRewards: totalRewards
                };
                
                // 主邀请码（第一个）
                const mainCode = codes[0];
                
                invitationSection.innerHTML = `
                    <div style="padding: 20px;">
                        <!-- 主邀请码展示 -->
                        <div style="
                            background: linear-gradient(135deg, var(--st-primary-500), var(--st-primary-700));
                            border-radius: 15px;
                            padding: 25px;
                            color: white;
                            margin-bottom: 20px;
                            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
                            position: relative;
                            overflow: hidden;
                        ">
                            <div style="position: absolute; top: -20px; right: -20px; font-size: 100px; opacity: 0.1;">
                                <i class="fas fa-gift"></i>
                            </div>
                            <div style="position: relative; z-index: 1;">
                                <div style="font-size: 14px; opacity: 0.9; margin-bottom: 10px;">
                                    <i class="fas fa-star"></i> 我的专属邀请码
                                </div>
                                <div style="
                                    font-size: 36px;
                                    font-weight: 700;
                                    letter-spacing: 6px;
                                    margin-bottom: 15px;
                                    font-family: 'Courier New', monospace;
                                    text-shadow: 0 2px 4px rgba(0,0,0,0.2);
                                ">${mainCode.code}</div>
                                <div style="display: flex; gap: 10px;">
                                    <button onclick="copyInviteCode('${mainCode.code}')" style="
                                        flex: 1;
                                        padding: 12px;
                                        background: rgba(255, 255, 255, 0.2);
                                        border: 1px solid rgba(255, 255, 255, 0.3);
                                        color: white;
                                        border-radius: 10px;
                                        cursor: pointer;
                                        font-size: 14px;
                                        font-weight: 600;
                                        transition: all 0.3s;
                                    " onmouseover="this.style.background='rgba(255,255,255,0.35)'" 
                                       onmouseout="this.style.background='rgba(255,255,255,0.2)'">
                                        <i class="fas fa-copy"></i> 复制邀请码
                                    </button>
                                    <button onclick="shareInviteCode('${mainCode.code}')" style="
                                        flex: 1;
                                        padding: 12px;
                                        background: rgba(255, 255, 255, 0.2);
                                        border: 1px solid rgba(255, 255, 255, 0.3);
                                        color: white;
                                        border-radius: 10px;
                                        cursor: pointer;
                                        font-size: 14px;
                                        font-weight: 600;
                                        transition: all 0.3s;
                                    " onmouseover="this.style.background='rgba(255,255,255,0.35)'" 
