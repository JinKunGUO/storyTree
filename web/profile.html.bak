        // ========== AI 使用统计 ==========
        
        // 加载 AI 使用统计
        async function loadAiUsageStats() {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/ai/v2/quota', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                const aiUsageSection = document.getElementById('aiUsageStats');

                if (!response.ok) {
                    aiUsageSection.innerHTML = `
                        <div class="empty-state">
                            <i class="fas fa-robot"></i>
                            <p>暂无 AI 使用数据</p>
                        </div>
                    `;
                    return;
                }

                const data = await response.json();
                const quotaInfo = data.quota || data.quotas;
                const costs = data.costs || {};
                
                // 计算各项配额的使用情况
                const continuation = quotaInfo?.continuation || { limit: 0, used: 0, unlimited: false };
                const polish = quotaInfo?.polish || { limit: 0, used: 0, unlimited: false };
                const illustration = quotaInfo?.illustration || { limit: 0, used: 0, unlimited: false };
                
                // 计算剩余次数
                const continuationRemaining = continuation.unlimited ? -1 : Math.max(0, continuation.limit - continuation.used);
                const polishRemaining = polish.unlimited ? -1 : Math.max(0, polish.limit - polish.used);
                const illustrationRemaining = illustration.unlimited ? -1 : Math.max(0, illustration.limit - illustration.used);
                
                // 获取用户积分
                let userPoints = 0;
                try {
                    const userResponse = await fetch('/api/auth/me', {
                        headers: {
                            'Authorization': `Bearer ${token}`
                        }
                    });
                    if (userResponse.ok) {
                        const userData = await userResponse.json();
                        userPoints = userData.user.points || 0;
                    }
                } catch (e) {
                    console.error('获取用户积分失败:', e);
                }
                
                aiUsageSection.innerHTML = `
                    <!-- AI 配额汇总 -->
                    <div class="ai-usage-summary">
                        <div class="ai-usage-card continuation">
                            <div class="ai-usage-icon">
                                <i class="fas fa-pen-fancy" style="color: #2196f3;"></i>
                            </div>
                            <div class="ai-usage-value">${continuationRemaining === -1 ? '∞' : continuationRemaining}</div>
                            <div class="ai-usage-label">AI 续写剩余</div>
                            <div class="ai-usage-detail">
                                <i class="fas fa-coins" style="color: #ffd700;"></i>
                                消耗：${costs.continuation || 10}积分/次
                            </div>
                        </div>
                        
                        <div class="ai-usage-card polish">
                            <div class="ai-usage-icon">
                                <i class="fas fa-magic" style="color: #9c27b0;"></i>
                            </div>
                            <div class="ai-usage-value">${polishRemaining === -1 ? '∞' : polishRemaining}</div>
                            <div class="ai-usage-label">AI 润色剩余</div>
                            <div class="ai-usage-detail">
                                <i class="fas fa-coins" style="color: #ffd700;"></i>
                                消耗：${costs.polish || 3}积分/次
                            </div>
                        </div>
                        
                        <div class="ai-usage-card illustration">
                            <div class="ai-usage-icon">
                                <i class="fas fa-image" style="color: #ff9800;"></i>
                            </div>
                            <div class="ai-usage-value">${illustrationRemaining === -1 ? '∞' : illustrationRemaining}</div>
                            <div class="ai-usage-label">AI 插图剩余</div>
                            <div class="ai-usage-detail">
                                <i class="fas fa-coins" style="color: #ffd700;"></i>
                                消耗：${costs.illustration || 20}积分/张
                            </div>
                        </div>
                        
                        <div class="ai-usage-card points">
                            <div class="ai-usage-icon">
                                <i class="fas fa-coins" style="color: #4caf50;"></i>
                            </div>
                            <div class="ai-usage-value" style="color: #4caf50;">${userPoints}</div>
                            <div class="ai-usage-label">当前积分</div>
                            <div class="ai-usage-detail">
                                <i class="fas fa-lightbulb"></i>
                                积分不足时使用
                            </div>
                        </div>
                    </div>

                    <!-- 使用说明 -->
                    <div class="ai-usage-history">
                        <h3>
                            <i class="fas fa-info-circle" style="color: var(--st-primary-500);"></i>
                            使用说明
                        </h3>
                        <div style="
                            background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
                            border-radius: 10px;
                            padding: 20px;
                            border-left: 4px solid var(--st-primary-500);
                        ">
                            <ul style="margin: 0; padding-left: 20px; line-height: 2; color: #666;">
                                <li><strong>配额限制：</strong>每个用户每月有免费的 AI 使用配额</li>
                                <li><strong>积分消耗：</strong>配额用完后，可以使用积分继续使用该功能</li>
                                <li><strong>会员特权：</strong>升级会员可获得更多配额和更高上限</li>
                            </ul>
                        </div>
                    </div>
                `;
            } catch (error) {
                console.error('加载 AI 使用统计错误:', error);
                document.getElementById('aiUsageStats').innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-exclamation-circle"></i>
                        <p>加载失败</p>
                    </div>
                `;
            }
        }

        // 显示提现对话框
        function showWithdrawalDialog() {
            const overlay = document.createElement('div');
            overlay.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.5);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10000;
                animation: fadeIn 0.3s;
            `;
            
            overlay.innerHTML = `
                <div style="
                    background: white;
                    border-radius: 20px;
                    padding: 30px;
                    max-width: 500px;
                    width: 90%;
                    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
                    animation: slideUp 0.3s;
                ">
                    <h2 style="margin: 0 0 20px 0; color: #333;">
                        <i class="fas fa-hand-holding-usd" style="color: #4caf50;"></i> 
                        申请提现
                    </h2>
                    
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; color: #666; font-weight: 600; margin-bottom: 8px;">
                            提现金额（积分）
                        </label>
                        <input type="number" id="withdrawalAmount" placeholder="最低100积分" min="100" style="
                            width: 100%;
                            padding: 12px;
                            border: 2px solid #e0e0e0;
                            border-radius: 10px;
                            font-size: 16px;
                            box-sizing: border-box;
                        ">
                    </div>
                    
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; color: #666; font-weight: 600; margin-bottom: 8px;">
                            提现方式
                        </label>
                        <select id="paymentMethod" style="
                            width: 100%;
                            padding: 12px;
                            border: 2px solid #e0e0e0;
                            border-radius: 10px;
                            font-size: 16px;
                            box-sizing: border-box;
                        ">
                            <option value="支付宝">支付宝</option>
                            <option value="微信">微信</option>
                            <option value="银行卡">银行卡</option>
                        </select>
                    </div>
                    
                    <div style="margin-bottom: 25px;">
                        <label style="display: block; color: #666; font-weight: 600; margin-bottom: 8px;">
                            提现账号
                        </label>
                        <input type="text" id="paymentAccount" placeholder="请输入账号" style="
                            width: 100%;
                            padding: 12px;
                            border: 2px solid #e0e0e0;
                            border-radius: 10px;
                            font-size: 16px;
                            box-sizing: border-box;
                        ">
                    </div>
                    
                    <p style="color: #999; font-size: 13px; margin-bottom: 20px; line-height: 1.6;">
                        <i class="fas fa-info-circle"></i>
                        提现申请提交后，管理员将在3-5个工作日内审核。审核通过后，款项将转入你的账户。
                    </p>
                    
                    <div style="display: flex; gap: 15px;">
                        <button onclick="this.closest('div').parentElement.remove()" style="
                            flex: 1;
                            padding: 12px;
                            background: #f5f5f5;
                            color: #666;
                            border: none;
                            border-radius: 10px;
                            font-size: 16px;
                            font-weight: 600;
                            cursor: pointer;
                        ">取消</button>
                        <button onclick="submitWithdrawal()" style="
                            flex: 1;
                            padding: 12px;
                            background: linear-gradient(135deg, #4caf50, #66bb6a);
                            color: white;
                            border: none;
                            border-radius: 10px;
                            font-size: 16px;
                            font-weight: 600;
                            cursor: pointer;
                        ">提交申请</button>
                    </div>
                </div>
            `;
            
            overlay.onclick = (e) => {
                if (e.target === overlay) {
                    overlay.remove();
                }
            };
            
            document.body.appendChild(overlay);
        }

        // 提交提现申请
        async function submitWithdrawal() {
            const amount = parseInt(document.getElementById('withdrawalAmount').value);
            const paymentMethod = document.getElementById('paymentMethod').value;
            const paymentAccount = document.getElementById('paymentAccount').value.trim();

            if (!amount || amount < 100) {
                window.toast ? toast.warning('提现金额最低为100积分') : alert('提现金额最低为100积分');
                return;
            }

            if (!paymentAccount) {
                window.toast ? toast.warning('请输入提现账号') : alert('请输入提现账号');
                return;
            }

            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/withdrawals/request', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        amount,
                        paymentMethod,
                        paymentAccount
                    })
                });

                const data = await response.json();
                
                // 移除对话框
                document.querySelectorAll('body > div').forEach(div => {
                    if (div.style.position === 'fixed') {
                        div.remove();
                    }
                });
                
                if (response.ok) {
                    window.toast ? toast.success(data.message) : alert('✅ ' + data.message);
                    // 刷新收益统计
                    await loadEarningsStats();
                } else {
                    window.toast ? toast.error(data.error || '提现申请失败') : alert('❌ ' + (data.error || '提现申请失败'));
                }
            } catch (error) {
                console.error('提交提现申请失败:', error);
                window.toast ? toast.error('提交失败，请稍后重试') : alert('提交失败，请稍后重试');
            }
        }

        // 显示提现记录
        async function showWithdrawalHistory() {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/withdrawals/my-requests', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (!response.ok) {
                    window.toast ? toast.error('加载提现记录失败') : alert('加载提现记录失败');
                    return;
                }

                const data = await response.json();
                const requests = data.requests || [];
                
                const overlay = document.createElement('div');
                overlay.style.cssText = `
                    position: fixed;
                    top: 0;
                    left: 0;
                    right: 0;
                    bottom: 0;
                    background: rgba(0, 0, 0, 0.5);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    z-index: 10000;
                    animation: fadeIn 0.3s;
                `;
                
                const statusMap = {
                    pending: { text: '待审核', color: '#ff9800' },
                    approved: { text: '已通过', color: '#4caf50' },
                    rejected: { text: '已拒绝', color: '#f44336' }
                };
                
                overlay.innerHTML = `
                    <div style="
                        background: white;
                        border-radius: 20px;
                        padding: 30px;
                        max-width: 700px;
                        width: 90%;
                        max-height: 80vh;
                        overflow-y: auto;
                        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
                        animation: slideUp 0.3s;
                    ">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                            <h2 style="margin: 0; color: #333;">
                                <i class="fas fa-history"></i> 
                                提现记录
                            </h2>
                            <button onclick="this.closest('div').parentElement.remove()" style="
                                background: none;
                                border: none;
                                font-size: 24px;
                                cursor: pointer;
                                color: #999;
                                padding: 0;
                                width: 32px;
                                height: 32px;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                border-radius: 50%;
                                transition: all 0.3s;
                            " onmouseover="this.style.background='#f0f0f0'; this.style.color='#333';" 
                               onmouseout="this.style.background='none'; this.style.color='#999';">
                                ×
                            </button>
                        </div>
                        
                        ${requests.length === 0 ? `
                            <div style="text-align: center; padding: 40px; color: #999;">
                                <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 15px;"></i>
                                <p>还没有提现记录</p>
                            </div>
                        ` : requests.map(req => {
                            const status = statusMap[req.status] || { text: req.status, color: '#999' };
                            return `
                                <div style="
                                    padding: 20px;
                                    background: #f8f9fa;
                                    border-radius: 15px;
                                    margin-bottom: 15px;
                                ">
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                                        <div>
                                            <span style="
                                                font-size: 24px;
                                                font-weight: 700;
                                                color: #333;
                                            ">${req.amount} 积分</span>
                                        </div>
                                        <span style="
                                            padding: 6px 12px;
                                            background: ${status.color};
                                            color: white;
                                            border-radius: 20px;
                                            font-size: 13px;
                                            font-weight: 600;
                                        ">${status.text}</span>
                                    </div>
                                    <div style="color: #666; font-size: 14px; line-height: 1.8;">
                                        <div><i class="fas fa-credit-card"></i> ${escapeHtml(req.payment_method)}</div>
                                        <div><i class="fas fa-user"></i> ${escapeHtml(req.payment_account)}</div>
                                        <div><i class="fas fa-clock"></i> ${formatDate(req.created_at)}</div>
                                        ${req.admin_note ? `<div style="color: #f44336;"><i class="fas fa-comment"></i> ${escapeHtml(req.admin_note)}</div>` : ''}
                                    </div>
                                    ${req.status === 'pending' ? `
                                        <button onclick="cancelWithdrawal(${req.id})" style="
                                            margin-top: 15px;
                                            padding: 8px 16px;
                                            background: #f44336;
                                            color: white;
                                            border: none;
                                            border-radius: 8px;
                                            cursor: pointer;
                                            font-size: 13px;
                                            font-weight: 600;
                                        ">取消申请</button>
                                    ` : ''}
                                </div>
                            `;
                        }).join('')}
                    </div>
                `;
                
                overlay.onclick = (e) => {
                    if (e.target === overlay) {
                        overlay.remove();
                    }
                };
                
                document.body.appendChild(overlay);
            } catch (error) {
                console.error('加载提现记录失败:', error);
                window.toast ? toast.error('加载失败，请稍后重试') : alert('加载失败，请稍后重试');
            }
        }

        // 取消提现申请
        async function cancelWithdrawal(requestId) {
            const doCancel = async () => {
                try {
                    const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                    
                    const response = await fetch(`/api/withdrawals/${requestId}/cancel`, {
                        method: 'POST',
                        headers: { 'Authorization': `Bearer ${token}` }
                    });

                    const data = await response.json();
                    
                    if (response.ok) {
                        window.toast ? toast.success(data.message) : alert('✅ ' + data.message);
                        // 关闭对话框
                        document.querySelectorAll('body > div').forEach(div => {
                            if (div.style.position === 'fixed') div.remove();
                        });
                        // 刷新收益统计
                        await loadEarningsStats();
                    } else {
                        window.toast ? toast.error(data.error || '取消失败') : alert('❌ ' + (data.error || '取消失败'));
                    }
                } catch (error) {
                    console.error('取消提现申请失败:', error);
                    window.toast ? toast.error('操作失败，请稍后重试') : alert('操作失败，请稍后重试');
                }
            };

            if (window.showDangerConfirm) {
                showDangerConfirm('确定要取消这个提现申请吗？金额将退回到收益余额。', doCancel, { title: '取消提现', confirmText: '确认取消' });
            } else if (confirm('确定要取消这个提现申请吗？金额将退回到收益余额。')) {
                await doCancel();
            }
        }

        // ========== 签到系统 ==========
        let currentCalendarYear = new Date().getFullYear();
        let currentCalendarMonth = new Date().getMonth() + 1;
        let checkinRecords = [];
        let checkinStatus = null;

        // 计算当前查看月份的已用补签次数
        function getMonthMakeupUsed() {
            const now = new Date();
            const currentYear = now.getFullYear();
            const currentMonth = now.getMonth() + 1;
            // 只统计当前自然月的补签次数（与后端逻辑一致）
            return checkinRecords.filter(r => {
                if (!r.is_makeup) return false;
                const d = new Date(r.checkin_date);
                return d.getFullYear() === currentYear && d.getMonth() + 1 === currentMonth;
            }).length;
        }

        // 加载签到状态
        async function loadCheckinStatus() {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/checkin/status', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (!response.ok) {
                    console.error('加载签到状态失败');
                    return;
                }

                const data = await response.json();
                checkinStatus = data;
                
                // 更新紧凑版签到框显示
                const compactConsecutiveDays = document.getElementById('compactConsecutiveDays');
                const compactMakeupChances = document.getElementById('compactMakeupChances');
                const compactCheckinMessage = document.getElementById('compactCheckinMessage');
                
                if (compactConsecutiveDays) compactConsecutiveDays.textContent = data.consecutiveDays || 0;
                if (compactMakeupChances) compactMakeupChances.textContent = data.makeupChances || 0;
                
                // 显示签到状态提示
                if (compactCheckinMessage) {
                    if (!data.canCheckin) {
                        compactCheckinMessage.className = 'compact-checkin-message info show';
                        compactCheckinMessage.textContent = '今天已签到';
                    } else if (data.isMissed) {
                        compactCheckinMessage.className = 'compact-checkin-message info show';
                        compactCheckinMessage.textContent = '连续签到已中断，点击今天日期签到';
                    } else {
                        compactCheckinMessage.className = 'compact-checkin-message';
                    }
                }
                
                // 加载签到历史（同时更新大日历和紧凑日历）
                await loadCheckinHistory(currentCalendarYear, currentCalendarMonth);
            } catch (error) {
                console.error('加载签到状态错误:', error);
            }
        }

        // 每日签到
        async function dailyCheckin() {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/checkin/daily', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                const data = await response.json();
                
                if (response.ok) {
                    // 显示成功消息（使用临时提示）
                    let message = `🎉 ${data.message} 获得 ${data.data.pointsEarned} 积分！`;
                    
                    if (data.data.bonusPoints > 0) {
                        message += ` 🎁 ${data.data.milestoneMessage}额外奖励 ${data.data.bonusPoints} 积分！`;
                    }
                    
                    if (data.data.bonusMakeupChances > 0) {
                        message += ` 🎁 获得 ${data.data.bonusMakeupChances} 次补签机会！`;
                    }
                    
                    // 创建临时消息提示
                    showMessage(message, 'success');
                    
                    // 刷新签到状态和日历
                    await loadCheckinStatus();
                    await loadUserProfile(); // 刷新用户信息（更新积分）
                } else {
                    // 显示错误消息
                    showMessage('❌ ' + (data.error || '签到失败'), 'error');
                }
            } catch (error) {
                console.error('签到失败:', error);
                showMessage('❌ 签到失败，请稍后重试', 'error');
            }
        }

        // 加载签到历史
        async function loadCheckinHistory(year, month) {
            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch(`/api/checkin/history?year=${year}&month=${month}`, {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (!response.ok) {
                    console.error('加载签到历史失败');
                    return;
                }

                const data = await response.json();
                checkinRecords = data.records || [];
                
                // 更新统计信息
                document.getElementById('totalCheckins').textContent = data.stats.totalCheckins || 0;
                document.getElementById('totalCheckinPoints').textContent = data.stats.totalPoints || 0;
                document.getElementById('makeupCount').textContent = data.stats.makeupCount || 0;
                
                // 更新本月补签已用次数展示
                const monthUsed = getMonthMakeupUsed();
                const monthMakeupHint = document.getElementById('monthMakeupHint');
                if (monthMakeupHint) {
                    if (checkinStatus?.makeupChances > 0 && monthUsed < 3) {
                        monthMakeupHint.textContent = `本月已用 ${monthUsed}/3 次`;
                        monthMakeupHint.style.color = '#ff9800';
                    } else if (monthUsed >= 3) {
                        monthMakeupHint.textContent = '本月补签次数已达上限';
                        monthMakeupHint.style.color = '#94a3b8';
                    } else {
                        monthMakeupHint.textContent = '补签机会不足';
                        monthMakeupHint.style.color = '#94a3b8';
                    }
                }
                
                // 渲染日历
                renderCalendar(year, month);
            } catch (error) {
                console.error('加载签到历史错误:', error);
            }
        }

        // 渲染日历
        function renderCalendar(year, month) {
            // 渲染大日历
            const calendarGrid = document.getElementById('calendarGrid');
            const calendarMonth = document.getElementById('calendarMonth');
            
            // 渲染紧凑版日历
            const compactCalendarGrid = document.getElementById('compactCalendarGrid');
            const compactCalendarMonth = document.getElementById('compactCalendarMonth');
            
            // 更新月份显示
            if (calendarMonth) calendarMonth.textContent = `${year}年${month}月`;
            if (compactCalendarMonth) compactCalendarMonth.textContent = `${year}年${month}月`;
            
            // 获取当月第一天和最后一天
            const firstDay = new Date(year, month - 1, 1);
            const lastDay = new Date(year, month, 0);
            const daysInMonth = lastDay.getDate();
            const firstDayOfWeek = firstDay.getDay(); // 0-6 (周日-周六)
            
            // 渲染大日历
            if (calendarGrid) {
                // 清空现有日期（保留星期标题）
                const dayHeaders = Array.from(calendarGrid.children).slice(0, 7);
                calendarGrid.innerHTML = '';
                dayHeaders.forEach(header => calendarGrid.appendChild(header));
                
                renderCalendarDays(calendarGrid, year, month, firstDayOfWeek, daysInMonth, 'calendar-day');
            }
            
            // 渲染紧凑版日历
            if (compactCalendarGrid) {
                // 清空现有日期（保留星期标题）
                const compactHeaders = Array.from(compactCalendarGrid.children).slice(0, 7);
                compactCalendarGrid.innerHTML = '';
                compactHeaders.forEach(header => compactCalendarGrid.appendChild(header));
                
                renderCalendarDays(compactCalendarGrid, year, month, firstDayOfWeek, daysInMonth, 'compact-calendar-day');
            }
        }
        
// 渲染日历天数（通用函数）
        function renderCalendarDays(gridElement, year, month, firstDayOfWeek, daysInMonth, dayClass) {
            // 填充上个月的日期
            const prevMonthLastDay = new Date(year, month - 1, 0).getDate();
            for (let i = firstDayOfWeek - 1; i >= 0; i--) {
                const day = prevMonthLastDay - i;
                const dayElement = document.createElement('div');
                dayElement.className = `${dayClass} other-month`;
                dayElement.textContent = day;
                gridElement.appendChild(dayElement);
            }
            
            // 填充当月日期
            const today = new Date();
            const isCurrentMonth = today.getFullYear() === year && today.getMonth() + 1 === month;
            
            for (let day = 1; day <= daysInMonth; day++) {
                const dayElement = document.createElement('div');
                dayElement.className = dayClass;
                dayElement.textContent = day;
                
                const dateStr = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const record = checkinRecords.find(r => {
                    const recordDate = new Date(r.checkin_date);
                    return recordDate.getFullYear() === year &&
                           recordDate.getMonth() + 1 === month &&
                           recordDate.getDate() === day;
                });
                
                // 今天 - 添加点击签到功能
                if (isCurrentMonth && day === today.getDate()) {
                    dayElement.classList.add('today');
                    // 如果今天可以签到，添加点击事件
                    if (!record && checkinStatus?.canCheckin) {
                        dayElement.style.cursor = 'pointer';
                        dayElement.title = '点击签到';
                        dayElement.onclick = (e) => {
                            e.stopPropagation();
                            dailyCheckin();
                        };
                    } else if (record) {
                        dayElement.title = '今天已签到';
                    }
                }
                
                // 已签到
                if (record) {
                    if (record.is_makeup) {
                        dayElement.classList.add('makeup');
                        dayElement.title = `补签 +${record.points_earned}积分`;
                    } else {
                        dayElement.classList.add('checked');
                        dayElement.title = `已签到 +${record.points_earned}积分`;
                    }
                } else {
                    // 可补签的日期（最近 7 天内，且有补签机会，且本月补签未超 3 次）
                    const dayDate = new Date(year, month - 1, day);
                    const diffTime = today - dayDate;
                    const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
                    
                    if (diffDays > 0 && diffDays <= 7 && checkinStatus?.makeupChances > 0 && getMonthMakeupUsed() < 3) {
                        dayElement.classList.add('can-makeup');
                        dayElement.title = '点击补签';
                        dayElement.onclick = () => showMakeupDialog(dateStr);
                    }
                }
                
                gridElement.appendChild(dayElement);
            }
            
            // 填充下个月的日期
            const remainingDays = 42 - (firstDayOfWeek + daysInMonth); // 6 行 7 列=42 个格子
            for (let day = 1; day <= remainingDays; day++) {
                const dayElement = document.createElement('div');
                dayElement.className = `${dayClass} other-month`;
                dayElement.textContent = day;
                gridElement.appendChild(dayElement);
            }
        }

        // 切换月份
        function changeMonth(delta) {
            currentCalendarMonth += delta;
            
            if (currentCalendarMonth > 12) {
                currentCalendarMonth = 1;
                currentCalendarYear++;
            } else if (currentCalendarMonth < 1) {
                currentCalendarMonth = 12;
                currentCalendarYear--;
            }
            
            loadCheckinHistory(currentCalendarYear, currentCalendarMonth);
        }

        // 显示补签对话框
        function showMakeupDialog(date) {
            // 前端预检：检查月度补签次数
            const monthUsed = getMonthMakeupUsed();
            if (monthUsed >= 3) {
                showMessage('本月补签次数已达上限（每月最多3次）', 'error');
                return;
            }
            
            // 检查补签机会余额
            if (!checkinStatus || checkinStatus.makeupChances <= 0) {
                showMessage('补签机会不足', 'error');
                return;
            }
            
            const overlay = document.createElement('div');
            overlay.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.5);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10000;
                animation: fadeIn 0.3s;
            `;
            
            overlay.innerHTML = `
                <div style="
                    background: white;
                    border-radius: 20px;
                    padding: 30px;
                    max-width: 400px;
                    width: 90%;
                    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
                    animation: slideUp 0.3s;
                ">
                    <h2 style="margin: 0 0 20px 0; color: #333;">
                        <i class="fas fa-calendar-check" style="color: #ff9800;"></i> 
                        补签确认
                    </h2>
                    
                    <p style="color: #666; line-height: 1.6; margin-bottom: 20px;">
                        确定要补签 <strong style="color: var(--st-primary-500);">${new Date(date).toLocaleDateString('zh-CN')}</strong> 吗？
                    </p>
                    
                    <p style="color: #999; font-size: 14px; margin-bottom: 25px;">
                        <i class="fas fa-info-circle"></i>
                        消耗1次补签机会，当前剩余 <strong style="color: #ff9800;">${checkinStatus?.makeupChances || 0}</strong> 次
                        <br>
                        <i class="fas fa-calendar-alt" style="margin-top: 8px; display: inline-block;"></i>
                        本月已用补签 <strong style="color: #ff9800;">${getMonthMakeupUsed()}/3</strong> 次
                    </p>
                    
                    <div style="display: flex; gap: 15px;">
                        <button onclick="this.closest('div').parentElement.remove()" style="
                            flex: 1;
                            padding: 12px;
                            background: #f5f5f5;
                            color: #666;
                            border: none;
                            border-radius: 10px;
                            font-size: 16px;
                            font-weight: 600;
                            cursor: pointer;
                        ">取消</button>
                        <button onclick="performMakeup('${date}')" style="
                            flex: 1;
                            padding: 12px;
                            background: linear-gradient(135deg, #ff9800, #ffa726);
                            color: white;
                            border: none;
                            border-radius: 10px;
                            font-size: 16px;
                            font-weight: 600;
                            cursor: pointer;
                        ">确认补签</button>
                    </div>
                </div>
            `;
            
            overlay.onclick = (e) => {
                if (e.target === overlay) {
                    overlay.remove();
                }
            };
            
            document.body.appendChild(overlay);
        }

        // 执行补签
        async function performMakeup(date) {
            // 先关闭补签对话框
            document.querySelectorAll('body > div').forEach(div => {
                if (div.style.position === 'fixed') {
                    div.remove();
                }
            });

            try {
                const token = localStorage.getItem('token') || sessionStorage.getItem('token');
                
                const response = await fetch('/api/checkin/makeup', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ date })
                });

                const data = await response.json();
                
                if (response.ok) {
                    // 使用 toast 显示成功（不依赖 DOM 中的 checkinMessage 元素）
                    showMessage(`🎉 ${data.message} 获得 ${data.data.pointsEarned} 积分！剩余补签机会: ${data.data.remainingMakeupChances}`, 'success');
                    
                    // 刷新签到状态和日历
                    await loadCheckinStatus();
                    await loadUserProfile();
                } else {
                    showMessage(data.error || '补签失败', 'error');
                }
            } catch (error) {
                console.error('补签失败:', error);
                showMessage('补签失败，请稍后重试', 'error');
            }
        }

        // ========== 编辑资料弹窗 ==========
        function showEditProfileModal() {
            // 移除已有弹窗（防止重复）
            const existing = document.getElementById('editProfileOverlay');
            if (existing) existing.remove();

            const overlay = document.createElement('div');
            overlay.id = 'editProfileOverlay';
            overlay.style.cssText = `
                position: fixed;
                top: 0; left: 0; right: 0; bottom: 0;
                background: rgba(0,0,0,0.5);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10000;
                animation: fadeIn 0.3s;
            `;

            overlay.innerHTML = `
                <div style="
                    background: white;
                    border-radius: 20px;
                    padding: 35px;
                    max-width: 480px;
                    width: 90%;
                    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
                    animation: slideUp 0.3s;
                ">
                    <!-- 标题 -->
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:25px;">
                        <h2 style="margin:0; color:#333; font-size:22px;">
                            <i class="fas fa-user-edit" style="color:var(--st-primary-500);"></i> 编辑资料
                        </h2>
                        <button onclick="document.getElementById('editProfileOverlay').remove()" style="
                            background:none; border:none; font-size:24px; cursor:pointer;
                            color:#999; width:32px; height:32px; display:flex;
                            align-items:center; justify-content:center; border-radius:50%;
                            transition:all 0.3s;
                        " onmouseover="this.style.background='#f0f0f0'; this.style.color='#333';"
                           onmouseout="this.style.background='none'; this.style.color='#999';">×</button>
                    </div>

                    <!-- Tab 切换 -->
                    <div style="display:flex; border-bottom:2px solid #f0f0f0; margin-bottom:25px;">
                        <button id="tabBasicBtn" onclick="switchEditTab('basic')" style="
                            flex:1; padding:10px; background:none; border:none; cursor:pointer;
                            font-size:15px; font-weight:600; color:var(--st-primary-500);
                            border-bottom:3px solid var(--st-primary-500); transition:all 0.3s;
                        ">
                            <i class="fas fa-id-card"></i> 基本信息
                        </button>
                        <button id="tabPasswordBtn" onclick="switchEditTab('password')" style="
                            flex:1; padding:10px; background:none; border:none; cursor:pointer;
                            font-size:15px; font-weight:600; color:#999;
                            border-bottom:3px solid transparent; transition:all 0.3s;
                        ">
                            <i class="fas fa-lock"></i> 修改密码
                        </button>
                    </div>

                    <!-- 基本信息 Tab -->
                    <div id="tabBasicContent">
                        <!-- 用户名 -->
                        <div style="margin-bottom:20px;">
                            <label style="display:block; font-weight:600; color:#555; margin-bottom:8px; font-size:14px;">
                                <i class="fas fa-user"></i> 用户名
                                <span style="color:#999; font-weight:normal; font-size:12px; margin-left:8px;">（3-20位，字母/数字/下划线/连字符）</span>
                            </label>
                            <input type="text" id="editUsername" placeholder="输入新用户名"
                                maxlength="20"
                                style="
                                    width:100%; padding:12px 15px; border:2px solid #e0e0e0;
                                    border-radius:10px; font-size:15px; outline:none;
                                    box-sizing:border-box; transition:all 0.3s;
                                "
                                onfocus="this.style.borderColor='var(--st-primary-500)'; this.style.boxShadow='0 0 0 3px rgba(102,126,234,0.1)';"
                                onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none';"
                            />
                        </div>
                        <!-- 个人简介 -->
                        <div style="margin-bottom:20px;">
                            <label style="display:block; font-weight:600; color:#555; margin-bottom:8px; font-size:14px;">
                                <i class="fas fa-pen"></i> 个人简介
                            </label>
                            <textarea id="editBio" placeholder="介绍一下自己..." rows="3"
                                maxlength="200"
                                style="
                                    width:100%; padding:12px 15px; border:2px solid #e0e0e0;
                                    border-radius:10px; font-size:15px; outline:none; resize:vertical;
                                    box-sizing:border-box; transition:all 0.3s; font-family:inherit;
                                "
                                onfocus="this.style.borderColor='var(--st-primary-500)'; this.style.boxShadow='0 0 0 3px rgba(102,126,234,0.1)';"
                                onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none';"
                            ></textarea>
                        </div>
                        <!-- 提示信息 -->
                        <div id="editBasicMsg" style="margin-bottom:15px; font-size:14px; display:none;"></div>
                        <!-- 保存按钮 -->
                        <button onclick="saveBasicProfile()" style="
                            width:100%; padding:14px; background:linear-gradient(135deg, var(--st-primary-500), var(--st-primary-700));
                            color:white; border:none; border-radius:12px; font-size:16px;
                            font-weight:600; cursor:pointer; transition:all 0.3s;
                        " onmouseover="this.style.opacity='0.9'; this.style.transform='translateY(-1px)';"
                           onmouseout="this.style.opacity='1'; this.style.transform='translateY(0)';">
                            <i class="fas fa-save"></i> 保存修改
                        </button>
                    </div>

                    <!-- 修改密码 Tab -->
                    <div id="tabPasswordContent" style="display:none;">
                        <!-- 当前密码 -->
                        <div style="margin-bottom:20px;">
                            <label style="display:block; font-weight:600; color:#555; margin-bottom:8px; font-size:14px;">
                                <i class="fas fa-key"></i> 当前密码
                            </label>
                            <input type="password" id="editCurrentPassword" placeholder="输入当前密码"
                                style="
                                    width:100%; padding:12px 15px; border:2px solid #e0e0e0;
                                    border-radius:10px; font-size:15px; outline:none;
                                    box-sizing:border-box; transition:all 0.3s;
                                "
                                onfocus="this.style.borderColor='var(--st-primary-500)'; this.style.boxShadow='0 0 0 3px rgba(102,126,234,0.1)';"
                                onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none';"
                            />
                        </div>
                        <!-- 新密码 -->
                        <div style="margin-bottom:20px;">
                            <label style="display:block; font-weight:600; color:#555; margin-bottom:8px; font-size:14px;">
                                <i class="fas fa-lock"></i> 新密码
                                <span style="color:#999; font-weight:normal; font-size:12px; margin-left:8px;">（至少6位）</span>
                            </label>
                            <input type="password" id="editNewPassword" placeholder="输入新密码"
                                style="
                                    width:100%; padding:12px 15px; border:2px solid #e0e0e0;
                                    border-radius:10px; font-size:15px; outline:none;
                                    box-sizing:border-box; transition:all 0.3s;
                                "
                                onfocus="this.style.borderColor='var(--st-primary-500)'; this.style.boxShadow='0 0 0 3px rgba(102,126,234,0.1)';"
                                onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none';"
                            />
                        </div>
                        <!-- 确认新密码 -->
                        <div style="margin-bottom:20px;">
                            <label style="display:block; font-weight:600; color:#555; margin-bottom:8px; font-size:14px;">
                                <i class="fas fa-lock"></i> 确认新密码
                            </label>
                            <input type="password" id="editConfirmPassword" placeholder="再次输入新密码"
                                style="
                                    width:100%; padding:12px 15px; border:2px solid #e0e0e0;
                                    border-radius:10px; font-size:15px; outline:none;
                                    box-sizing:border-box; transition:all 0.3s;
                                "
                                onfocus="this.style.borderColor='var(--st-primary-500)'; this.style.boxShadow='0 0 0 3px rgba(102,126,234,0.1)';"
                                onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none';"
                            />
                        </div>
                        <!-- 提示信息 -->
                        <div id="editPasswordMsg" style="margin-bottom:15px; font-size:14px; display:none;"></div>
                        <!-- 保存按钮 -->
                        <button onclick="savePassword()" style="
                            width:100%; padding:14px; background:linear-gradient(135deg, var(--st-primary-500), var(--st-primary-700));
                            color:white; border:none; border-radius:12px; font-size:16px;
                            font-weight:600; cursor:pointer; transition:all 0.3s;
                        " onmouseover="this.style.opacity='0.9'; this.style.transform='translateY(-1px)';"
                           onmouseout="this.style.opacity='1'; this.style.transform='translateY(0)';">
                            <i class="fas fa-lock"></i> 修改密码
                        </button>
                    </div>
                </div>
            `;

            // 点击遮罩关闭
            overlay.onclick = (e) => {
                if (e.target === overlay) overlay.remove();
            };

            document.body.appendChild(overlay);

            // 填充当前用户名和bio
            if (currentUser) {
                document.getElementById('editUsername').value = currentUser.username || '';
                document.getElementById('editBio').value = currentUser.bio || '';
            }
        }

        // 切换 Tab
        function switchEditTab(tab) {
            const basicContent = document.getElementById('tabBasicContent');
            const passwordContent = document.getElementById('tabPasswordContent');
            const basicBtn = document.getElementById('tabBasicBtn');
            const passwordBtn = document.getElementById('tabPasswordBtn');

            if (tab === 'basic') {
                basicContent.style.display = 'block';
                passwordContent.style.display = 'none';
                basicBtn.style.color = 'var(--st-primary-500)';
                basicBtn.style.borderBottomColor = 'var(--st-primary-500)';
                passwordBtn.style.color = '#999';
                passwordBtn.style.borderBottomColor = 'transparent';
            } else {
                basicContent.style.display = 'none';
                passwordContent.style.display = 'block';
                basicBtn.style.color = '#999';
                basicBtn.style.borderBottomColor = 'transparent';
                passwordBtn.style.color = 'var(--st-primary-500)';
                passwordBtn.style.borderBottomColor = 'var(--st-primary-500)';
                // 清空密码输入框
                document.getElementById('editCurrentPassword').value = '';
                document.getElementById('editNewPassword').value = '';
                document.getElementById('editConfirmPassword').value = '';
            }
        }

        // 显示编辑表单消息
        function showEditMsg(elementId, message, isError) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.style.display = 'block';
            el.style.padding = '10px 15px';
            el.style.borderRadius = '8px';
            el.style.fontWeight = '500';
            if (isError) {
                el.style.background = '#ffebee';
                el.style.color = '#f44336';
                el.style.border = '1px solid #ffcdd2';
            } else {
                el.style.background = '#e8f5e9';
                el.style.color = '#4caf50';
                el.style.border = '1px solid #c8e6c9';
            }
            el.textContent = message;
        }

        // 保存基本信息（用户名 + bio）
        async function saveBasicProfile() {
            const newUsername = document.getElementById('editUsername').value.trim();
            const newBio = document.getElementById('editBio').value.trim();
            const token = localStorage.getItem('token') || sessionStorage.getItem('token');

            // 用户名变更
            if (newUsername && newUsername !== currentUser.username) {
                const usernameRes = await fetch('/api/users/username', {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ username: newUsername })
                });
                const usernameData = await usernameRes.json();
                if (!usernameRes.ok) {
                    showEditMsg('editBasicMsg', '❌ ' + (usernameData.error || '修改用户名失败'), true);
                    return;
                }
            }

            // bio 变更（无论是否修改都提交，后端幂等）
            const bioRes = await fetch('/api/users/profile', {
                method: 'PUT',
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ bio: newBio })
            });
            const bioData = await bioRes.json();
            if (!bioRes.ok) {
                showEditMsg('editBasicMsg', '❌ ' + (bioData.error || '修改简介失败'), true);
                return;
            }

            showEditMsg('editBasicMsg', '✅ 修改成功！', false);

            // 刷新页面数据
            setTimeout(async () => {
                document.getElementById('editProfileOverlay')?.remove();
                await loadUserProfile();
            }, 800);
        }

        // 保存新密码
        async function savePassword() {
            const currentPassword = document.getElementById('editCurrentPassword').value;
            const newPassword = document.getElementById('editNewPassword').value;
            const confirmPassword = document.getElementById('editConfirmPassword').value;

            if (!currentPassword || !newPassword || !confirmPassword) {
                showEditMsg('editPasswordMsg', '❌ 请填写所有密码字段', true);
                return;
            }

            if (newPassword !== confirmPassword) {
                showEditMsg('editPasswordMsg', '❌ 两次输入的新密码不一致', true);
                return;
            }

            if (newPassword.length < 6) {
                showEditMsg('editPasswordMsg', '❌ 新密码长度至少为6位', true);
                return;
            }

            const token = localStorage.getItem('token') || sessionStorage.getItem('token');

            const res = await fetch('/api/users/password', {
                method: 'PUT',
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ currentPassword, newPassword })
            });

            const data = await res.json();

            if (!res.ok) {
                showEditMsg('editPasswordMsg', '❌ ' + (data.error || '修改密码失败'), true);
                return;
            }

            showEditMsg('editPasswordMsg', '✅ 密码修改成功！', false);

            // 清空输入框
            setTimeout(() => {
                document.getElementById('editCurrentPassword').value = '';
                document.getElementById('editNewPassword').value = '';
                document.getElementById('editConfirmPassword').value = '';
                document.getElementById('editPasswordMsg').style.display = 'none';
            }, 1500);
        }

        // 页面加载
        document.addEventListener('DOMContentLoaded', function() {
            if (checkAuthStatus()) {
                loadUserProfile();
            }
        });
    </script>
    <script src="js/loading.js"></script>
    <script src="js/toast.js"></script>
    <script src="js/modal.js"></script>
    <script src="js/navbar.js"></script>
</body>
</html>